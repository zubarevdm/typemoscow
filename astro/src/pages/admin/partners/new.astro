---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout pageTitle="Новый партнёр" activeCollection="partners">
  <p class="crumbs">
    <a href="/admin">Главная</a><span class="sep">·</span>
    <a href="/admin/partners">Партнёры</a><span class="sep">·</span>
    Новый
  </p>

  <div class="title-row">
    <h1 class="page-title">Новый партнёр</h1>
    <span class="status-pill status-pill--draft">черновик</span>
  </div>

  <form class="form-grid" data-edit-form data-collection="partners" data-action="create" data-redirect-to="/admin/partners">
    <div>
      <div class="field">
        <label class="field-label" for="name">Название <span class="required">·</span></label>
        <input id="name" name="name" type="text" class="input" required autofocus placeholder="Напр. «SHEVELIZM»" />
        <span class="field-hint">Появится как заголовок партнёра в блоке. Текстовый логотип в моноширинном шрифте.</span>
      </div>

      <div class="field">
        <label class="field-label" for="id">ID (slug) <span class="required">·</span></label>
        <input id="id" name="id" type="text" class="input" required placeholder="напр. shevelizm" pattern="[a-z0-9-]+" />
        <span class="field-hint">Только латиница + дефисы. Внутренний идентификатор — менять потом нельзя.</span>
      </div>

      <input type="hidden" name="logoType" value="text" />

      <div class="field">
        <label class="field-label" for="text">Описание <span class="required">·</span></label>
        <textarea id="text" name="text" class="textarea" rows="5" required placeholder="Кто это и какие у нас отношения"></textarea>
        <span class="field-hint">2–4 предложения. Появится под названием в блоке «Партнёры».</span>
      </div>
    </div>

    <aside class="preview">
      <p class="preview-tag">Как это работает</p>
      <p class="preview-note">
        После создания партнёр добавится в конец блока «Партнёры» на главной.
        Логотип отрендерится текстом — название будет показано шрифтом Disket Mono.
        Если хочется кастомный SVG-логотип, это уже разработка (не CMS) — напишите.
      </p>
    </aside>

    <div class="form-foot" style="grid-column: 1 / -1;">
      <a class="btn btn-ghost" href="/admin/partners">Отмена</a>
      <button type="submit" class="btn btn-primary"><span class="dot"></span> Создать</button>
    </div>
  </form>
</AdminLayout>
