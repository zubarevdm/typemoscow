---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
---

<AdminLayout pageTitle="Новый мастер" activeCollection="team">
  <p class="crumbs">
    <a href="/admin">Главная</a><span class="sep">·</span>
    <a href="/admin/team">Команда</a><span class="sep">·</span>
    Новый
  </p>

  <div class="title-row">
    <h1 class="page-title">Новый мастер</h1>
    <span class="status-pill status-pill--draft">черновик</span>
  </div>

  <form class="form-grid" data-edit-form data-collection="team" data-action="create" data-redirect-to="/admin/team">
    <div>
      <div class="fieldset-2">
        <div class="field">
          <label class="field-label" for="name">Имя <span class="required">·</span></label>
          <input id="name" name="name" type="text" class="input" required autofocus placeholder="Напр. «Сергей Иванов»" />
        </div>
        <div class="field">
          <label class="field-label" for="initials">Инициалы для аватара</label>
          <input id="initials" name="initials" type="text" class="input" maxlength="3" placeholder="СИ" />
          <span class="field-hint">1–2 буквы. Показываются в кружке вместо фото.</span>
        </div>
      </div>

      <div class="field">
        <label class="field-label" for="role">Роль</label>
        <input id="role" name="role" type="text" class="input" value="Мастер" />
        <span class="field-hint">«Мастер», «Управляющий», «Преподаватель» и т.&nbsp;п.</span>
      </div>

      <div class="field">
        <label class="field-label" for="bio">Био <span class="required">·</span></label>
        <textarea id="bio" name="bio" class="textarea" rows="5" required placeholder="2–4 предложения о мастере"></textarea>
        <span class="field-hint">Не больше 350 символов. Без эмодзи.</span>
      </div>

      <div class="field">
        <label class="field-label" for="tags">Теги</label>
        <input id="tags" name="tags" type="text" class="input" placeholder="с 2019, Борода, Управляющий" />
        <span class="field-hint">Через запятую. Появятся под био как кружки.</span>
      </div>

      <div class="field">
        <label class="field-label" for="photo-file">Фотография</label>
        <input id="photo-file" type="file" accept="image/jpeg,image/png,image/webp" class="file-input" data-upload-target="photo" data-upload-folder="team" />
        <span class="field-hint">JPG/PNG/WebP, до 8 МБ. Опционально — без фото покажутся инициалы.</span>
        <p class="upload-status" data-upload-status hidden></p>
      </div>

      <input type="hidden" name="photo" value="" />

      <div class="field">
        <label class="checkbox">
          <input type="checkbox" name="available" checked />
          <span class="box"></span>
          <span>Показывать мастера на сайте</span>
        </label>
      </div>
    </div>

    <aside class="preview">
      <p class="preview-tag">Как это работает</p>
      <p class="preview-note">
        После сохранения мастер появится в конце списка <a href="/admin/team">«Команда»</a>.
        Карточка отрисуется на главной с указанными инициалами и био. Загрузка фото —
        в следующей версии админки.
      </p>
    </aside>

    <div class="form-foot" style="grid-column: 1 / -1;">
      <a class="btn btn-ghost" href="/admin/team">Отмена</a>
      <button type="submit" class="btn btn-primary"><span class="dot"></span> Создать</button>
    </div>
  </form>
</AdminLayout>
