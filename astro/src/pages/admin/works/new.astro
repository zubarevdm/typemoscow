---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import works from '../../../content/works.json';

const nextNum = String(works.items.length + 1).padStart(2, '0');
---

<AdminLayout pageTitle="Новая работа" activeCollection="works">
  <p class="crumbs">
    <a href="/admin">Главная</a><span class="sep">·</span>
    <a href="/admin/works">Работы</a><span class="sep">·</span>
    Новая
  </p>

  <div class="title-row">
    <h1 class="page-title">Новая работа</h1>
    <span class="status-pill status-pill--draft">черновик</span>
  </div>

  <form class="form-grid" data-edit-form data-collection="works" data-action="create" data-redirect-to="/admin/works">
    <div>
      <div class="field">
        <label class="field-label" for="num">Номер</label>
        <input id="num" name="num" type="text" class="input" maxlength="2" value={nextNum} />
        <span class="field-hint">Двузначный. По умолчанию — следующий по порядку ({nextNum}).</span>
      </div>

      <div class="field">
        <label class="field-label" for="photo">Файл фотографии <span class="required">·</span></label>
        <input id="photo" type="file" accept="image/jpeg,image/png,image/webp" class="file-input" data-upload-target="src" />
        <span class="field-hint">JPG/PNG/WebP, до 8 МБ. Загрузится в <code>astro/public/assets/works/</code>.</span>
        <p class="upload-status" data-upload-status hidden></p>
      </div>

      <div class="field">
        <label class="field-label" for="src">Путь к файлу</label>
        <input id="src" name="src" type="text" class="input" required readonly placeholder="Заполнится автоматически после загрузки файла" />
        <span class="field-hint">Заполнится автоматически. Менять вручную нужно только если файл уже лежит в репо.</span>
      </div>

      <div class="field">
        <label class="field-label" for="alt">Альтернативный текст <span class="required">·</span></label>
        <input id="alt" name="alt" type="text" class="input" required placeholder="Напр. «Работа мастеров TYPE — 07»" />
        <span class="field-hint">Описание для поисковиков и читалок экрана.</span>
      </div>
    </div>

    <aside class="preview">
      <p class="preview-tag">Превью</p>
      <div class="work-prev">
        <img data-upload-preview alt="Превью" hidden />
        <div class="work-prev__empty" data-upload-empty>Выберите файл →</div>
        <span class="work-prev__num">{nextNum}</span>
      </div>
      <p class="preview-note">После «Создать» — два коммита: загрузка файла + запись в JSON. Сайт обновится за ~1 минуту.</p>
    </aside>

    <div class="form-foot" style="grid-column: 1 / -1;">
      <a class="btn btn-ghost" href="/admin/works">Отмена</a>
      <button type="submit" class="btn btn-primary"><span class="dot"></span> Создать</button>
    </div>
  </form>
</AdminLayout>

<style is:global>
  .work-prev {
    position: relative;
    aspect-ratio: 2 / 3;
    border-radius: 12px;
    overflow: hidden;
    background: var(--ink);
  }
  .work-prev img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }
  .work-prev__empty {
    position: absolute; inset: 0;
    display: grid; place-items: center;
    color: rgba(235,234,229,.5);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: 24px;
    text-align: center;
  }
  .work-prev__num {
    position: absolute;
    top: 14px; left: 14px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: .2em;
    color: rgba(235, 234, 229, .7);
  }
</style>
