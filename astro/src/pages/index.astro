        </div>

        <div class="hero-foot">
          <span class="hero-pill">{contacts.address.city} · Остоженка 47</span>
          <a href="#cta" class="hero-cta">Записаться онлайн <span class="arrow"></span></a>
          <span class="hero-secondary">Сегодня открыто <span style="color:var(--ash);">·</span> до 22:00</span>
        </div>
      </div>
    </section>

    <!-- УСЛУГИ -->
    <section class="services section-pad" id="services">
      <span class="topo" aria-hidden="true"></span>
      <div class="container section-content">
        <p class="section-tag">01 · SERVICES</p>

        <header class="services-head reveal">
          <div>
            <h2 class="h-section">Услуги <span class="marker"></span></h2>
          </div>
          <p class="lede">Мы подобрали для вас только те услуги, которые нужны мужчине нашего времени. Без лишней воды.</p>
        </header>

        <div class="services-cats reveal-stagger">
          {services.categories.map((cat, i) => (
            <div>
              <header class="services-cat-head">
                <span class="services-cat-name">{cat.name}</span>
                <span class="services-cat-tag">{String(i + 1).padStart(2, '0')} / {String(services.categories.length).padStart(2, '0')}</span>
              </header>
              {cat.id === 'packages' ? (
                <ul class="complex-list">
                  {cat.items.filter(it => it.available !== false).map(item => (
                    <li class="complex">
                      <span class="complex-name">{item.name}</span>
                      <span class="complex-price">{fmtPrice(item.price)}</span>
                      {item.description && <p class="complex-note">{item.description}</p>}
                    </li>
                  ))}
                </ul>
              ) : (
                <ul class="price-list">
                  {cat.items.filter(it => it.available !== false).map(item => (
                    <li class="price-row"><span class="name">{item.name}</span><span class="price">{fmtPrice(item.price)}</span></li>
                  ))}
                </ul>
              )}
            </div>
          ))}
        </div>

        <div class="services-foot">
          <span class="services-foot-note">{services.footnote}</span>
          <a href="#cta" class="btn btn-ghost">Записаться <span class="arrow"></span></a>
        </div>
      </div>
    </section>

    <!-- КОМАНДА -->
    <section class="team section-pad" id="team">
      <span class="topo" aria-hidden="true"></span>
      <div class="container section-content">
        <p class="section-tag">02 · TEAM</p>

        <header class="team-head reveal">
          <div>
            <h2 class="h-section">Команда TYPE <span class="marker"></span></h2>
          </div>
          <p class="lede">Грамотно подобранная команда профессионалов мужского сервиса. Каждый мастер — со своей историей и подходом.</p>
        </header>

        <div class="team-grid reveal-stagger">
          {team.masters.filter(m => m.available !== false).map((master, i) => (
            <article class="master">
              <div class="master-head">
                <span class="num">{String(i + 1).padStart(2, '0')}</span>
                <span class="role">{master.role}</span>
              </div>
              <div class="master-photo" data-init={master.initials} aria-label={`${master.name} — фото`}>
                {master.photo && <img src={master.photo} alt={master.name} loading="lazy" />}
              </div>
              <h3 class="master-name">{master.name}</h3>
              <p class="master-bio">{master.bio}</p>
              <div class="master-tags">
                {master.tags.map(tag => <span class="master-tag">{tag}</span>)}
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ИНТЕРЬЕР -->
    <section class="interior section-pad" id="interior">
      <span class="topo" aria-hidden="true"></span>
      <div class="container section-content">
        <p class="section-tag">03 · INTERIOR</p>

        <div class="reveal" style="max-width:780px;">
          <h2 class="h-section">Пространство <span class="marker"></span></h2>
          <p class="lede" style="margin-top:16px;">Интерьер, в котором стрижка превращается в паузу. Хром, бетон, зелень и тёплый свет — спокойная сцена для повседневного ритуала.</p>
        </div>
      </div>

      <div class="interior-wide">
        <div class="interior-grid reveal-stagger">
          <figure class="interior-figure wide span-2">
            <img src="/assets/interior/10.jpg" alt="TYPE — главный зал, ресепшн и рабочие станции" loading="lazy" decoding="async"/>
            <figcaption>Главный зал</figcaption>
          </figure>
          <figure class="interior-figure">
            <img src="/assets/interior/11.jpg" alt="Лаунж-зона TYPE с зелёными диванами" loading="lazy" decoding="async"/>
            <figcaption>Лаунж</figcaption>
          </figure>
          <figure class="interior-figure">
            <img src="/assets/interior/20.jpg" alt="Рабочие станции TYPE, вид со стороны входа" loading="lazy" decoding="async"/>
            <figcaption>Рабочие места</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- БОЛЬШОЙ CTA «ЗАПИСАТЬСЯ» -->
    <section class="cta" id="cta">
      <span class="topo" aria-hidden="true"></span>
      <div class="container cta-inner reveal">
        <p class="cta-tag">BOOKING</p>
        <h2 class="cta-title">Записаться</h2>
        <p class="cta-sub">Запись по телефону или через онлайн-сервис. Перезвоним в течение 5 минут и подберём время у нужного мастера.</p>
        <div class="cta-buttons">
          <a href={`tel:${contacts.phone.tel}`} class="btn btn-primary">Позвонить · {contacts.phone.display}</a>
          <a href={contacts.booking.yclients} target="_blank" rel="noopener noreferrer" class="btn btn-ghost">Онлайн-запись (YClients) <span class="arrow"></span></a>
        </div>
      </div>
    </section>

    <!-- КОНТАКТЫ -->
    <section class="contacts section-pad" id="contacts">
      <span class="topo" aria-hidden="true"></span>
      <div class="container section-content">
        <p class="section-tag">04 · CONTACTS</p>

        <div class="contacts-grid">
          <div class="reveal">
            <h2 class="h-section">Контакты <span class="marker"></span></h2>
            <p class="lede" style="margin-top:24px;">{contacts.address.city}, {contacts.address.street.replace('ул. ', '')}. {contacts.address.metro}, {contacts.address.district}. {contacts.address.entrance.charAt(0).toUpperCase() + contacts.address.entrance.slice(1)}.</p>

            <dl class="contacts-list">
              <div class="contacts-list-item">
                <dt>Запись</dt>
                <dd><a class="phone" href={`tel:${contacts.phone.tel}`}>{contacts.phone.display}</a></dd>
              </div>
              <div class="contacts-list-item">
                <dt>Почта</dt>
                <dd><a href={`mailto:${contacts.email}`}>{contacts.email}</a></dd>
              </div>
              <div class="contacts-list-item">
                <dt>Адрес</dt>
                <dd>г.&nbsp;{contacts.address.city}, {contacts.address.street}<span class="muted">{contacts.address.metro} · {contacts.address.district} · {contacts.address.entrance}</span></dd>
              </div>
              <div class="contacts-list-item">
                <dt>Часы</dt>
                <dd>{contacts.hours.display}<span class="muted">{contacts.hours.note}</span></dd>
              </div>
            </dl>
          </div>

          <div class="reveal">
            <div class="map-frame">
              <iframe
                src="https://yandex.ru/map-widget/v1/?ll=37.595713%2C55.737849&z=17&l=map"
                title="TYPE Barbershop на карте"
                allowfullscreen
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
              ></iframe>
              <a href={contacts.social.yandex_maps} target="_blank" rel="noopener" class="map-link">Открыть в Яндекс Картах →</a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ПАРТНЁРЫ -->
    <section class="partners section-pad" id="partners">
      <span class="topo" aria-hidden="true"></span>
      <div class="container section-content">
        <p class="section-tag">05 · PARTNERS</p>

        <div class="reveal" style="max-width:780px;">
          <h2 class="h-section">Наши партнёры <span class="marker"></span></h2>
        </div>

        <div class="partners-grid reveal-stagger">
          {partners.partners.map((p) => (
            <div class="partner-row">
              <div class="partner-logo" aria-label={p.name}>
                {p.logoType === 'image' && p.logoFile && (
                  <img class="partner-logo-img" src={p.logoFile} alt={p.name} loading="lazy" />
                )}
                {p.logoType === 'text' && p.id === 'betone' && <span class="logo-betone">BETONE</span>}
                {p.logoType === 'text' && p.id !== 'betone' && (
                  <span class="logo-text">{p.name}</span>
                )}
              </div>
              <p class="partner-text">{p.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

  </main>

  <!-- FOOTER -->
