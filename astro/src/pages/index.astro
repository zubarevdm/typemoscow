---
import services from '../content/services.json';
import team from '../content/team.json';
import contacts from '../content/contacts.json';
import partners from '../content/partners.json';
import site from '../content/site.json';
import CookieBanner from '../components/CookieBanner.astro';

// Форматирование цены: 6000 -> "6 000 ₽"
const fmtPrice = (n: number) => n.toLocaleString('ru-RU').replace(/,/g, ' ') + ' ₽';

// Schema.org HairSalon — собираем из JSON, чтобы не дублировать данные
const allPrices = services.categories.flatMap(c => c.items.map(i => i.price));
const minPrice = Math.min(...allPrices);
const maxPrice = Math.max(...allPrices);

const schemaJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'HairSalon',
  '@id': `${site.url}/#salon`,
  name: site.shortTitle,
  alternateName: 'ТАЙП Москва',
  description: 'Мужская парикмахерская на Остоженке. Стрижки, оформление бороды, классическое бритьё.',
  image: `${site.url}/assets/og-image.jpg`,
  logo: `${site.url}/assets/type-logo-main.svg`,
  url: `${site.url}/`,
  telephone: contacts.phone.tel,
  email: contacts.email,
  priceRange: `${minPrice}–${maxPrice} ₽`,
  currenciesAccepted: 'RUB',
  paymentAccepted: 'Cash, Credit Card',
  knowsLanguage: ['ru-RU'],
  publicAccess: true,
  smokingAllowed: false,
  isAccessibleForFree: false,
  areaServed: { '@type': 'City', name: contacts.address.city },
  address: {
    '@type': 'PostalAddress',
    streetAddress: contacts.address.street,
    addressLocality: contacts.address.city,
    addressRegion: contacts.address.city,
    postalCode: contacts.address.postalCode,
    addressCountry: contacts.address.country,
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: contacts.geo.lat,
    longitude: contacts.geo.lng,
  },
  openingHoursSpecification: [{
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
    opens: contacts.hours.opens,
    closes: contacts.hours.closes,
  }],
  sameAs: [
    contacts.social.instagram,
    contacts.social.telegram,
    contacts.social.vk,
  ],
  hasMap: contacts.social.yandex_maps,
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: `Услуги ${site.shortTitle}`,
    itemListElement: services.categories.flatMap(cat =>
      cat.items.filter(it => it.available !== false).map(item => ({
        '@type': 'Offer',
        url: `${site.url}/#services`,
        itemOffered: {
          '@type': 'Service',
          name: item.name,
          ...(item.description ? { description: item.description } : {}),
          serviceType: item.type || cat.name,
          category: cat.name,
          provider: {
            '@type': 'HairSalon',
            name: site.shortTitle,
            url: site.url,
          },
        },
        price: String(item.price),
        priceCurrency: 'RUB',
        priceSpecification: {
          '@type': 'UnitPriceSpecification',
          price: item.price,
          priceCurrency: 'RUB',
          valueAddedTaxIncluded: true,
        },
        availability: 'https://schema.org/InStock',
        businessFunction: 'http://purl.org/goodrelations/v1#Sell',
      }))
    ),
  },
};
---
<!doctype html>
<html lang={site.lang}>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#EBEAE5" />
  <meta name="description" content="TYPE Moscow — мужская парикмахерская на Остоженке 47. Стрижки, оформление бороды, классическое бритьё. Команда мастеров с 2009 года. Запись по телефону +7 965 31 31 31 5." />
  <meta name="keywords" content="барбершоп, мужская парикмахерская, стрижка Москва, борода, бритьё, Остоженка, TYPE Moscow, парк культуры барбер" />
  <meta name="author" content="TYPE Moscow" />
  <!-- STAGING-NOINDEX: на боевом домене заменить на content="index, follow" -->
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href={`${site.url}/`} />
  <title>TYPE Moscow — Мужская парикмахерская на Остоженке 47</title>

  <!-- Open Graph / Facebook / Telegram / VK -->
  <meta property="og:type" content="business.business" />
  <meta property="og:site_name" content="TYPE Moscow" />
  <meta property="og:title" content="TYPE Moscow — Мужская парикмахерская на Остоженке 47" />
  <meta property="og:description" content="Стрижки, оформление бороды, классическое бритьё. Команда мастеров мужского сервиса. Москва, Остоженка 47. Запись +7 965 31 31 31 5." />
  <meta property="og:url" content={`${site.url}/`} />
  <meta property="og:image" content={`${site.url}/assets/og-image.jpg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="TYPE Moscow — мужская парикмахерская на Остоженке 47" />
  <meta property="og:locale" content="ru_RU" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="TYPE Moscow — Мужская парикмахерская на Остоженке 47" />
  <meta name="twitter:description" content="Стрижки, оформление бороды, классическое бритьё. Москва, Остоженка 47." />
  <meta name="twitter:image" content={`${site.url}/assets/og-image.jpg`} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" media="print" onload="this.media='all'" />
  <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" /></noscript>
  <!-- Favicons + PWA -->
  <link rel="icon" type="image/svg+xml" href="/assets/type-mark.svg" />
  <link rel="icon" type="image/png" sizes="32x32" href="/assets/icons/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/assets/icons/favicon-16x16.png" />
  <link rel="shortcut icon" href="/favicon.ico" />
  <link rel="apple-touch-icon" sizes="180x180" href="/assets/icons/apple-touch-icon.png" />
  <link rel="manifest" href="/manifest.json" />
  <meta name="msapplication-config" content="browserconfig.xml" />
  <meta name="msapplication-TileColor" content="#0B0B0B" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="TYPE" />
  <meta name="application-name" content="TYPE Moscow" />

  <!-- Schema.org разметка — Яндекс/Google показывают как rich-snippet -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaJsonLd)}></script>

  <style>
  /* ============================================================
     TYPE — пересборка старого сайта в стилистике брендбука
     Структура 1:1 со старым типотом: Hero(video) → Услуги →
     Команда → CTA → Контакты → Партнёры
     Палитра: paper #EBEAE5 · ink #0B0B0B · forest #042615
     Шрифты:  Disket Mono (display) · Gotham/Montserrat (body)
     ============================================================ */

  @font-face { font-family: 'Disket Mono'; src: url('/assets/fonts/Disket-Mono-Regular.ttf') format('truetype'); font-weight: 400; font-display: swap; }
  @font-face { font-family: 'Disket Mono'; src: url('/assets/fonts/Disket-Mono-Bold.ttf') format('truetype');    font-weight: 700; font-display: swap; }
  /* Gotham ограничен латиницей. U+00A0 (nbsp) намеренно исключён —
     иначе nbsp между кириллическими словами берётся из Gotham и рендерится широченным пробелом. */
  @font-face { font-family: 'Gotham'; src: url('/assets/fonts/gotham_book.otf')   format('opentype'); font-weight: 400; font-display: swap; unicode-range: U+0020-009F, U+00A1-024F, U+1E00-1EFF, U+2000-206F, U+2070-209F, U+20A0-20CF, U+2100-214F; }
  @font-face { font-family: 'Gotham'; src: url('/assets/fonts/gotham_medium.otf') format('opentype'); font-weight: 500; font-display: swap; unicode-range: U+0020-009F, U+00A1-024F, U+1E00-1EFF, U+2000-206F, U+2070-209F, U+20A0-20CF, U+2100-214F; }
  @font-face { font-family: 'Gotham'; src: url('/assets/fonts/gotham_bold.otf')   format('opentype'); font-weight: 700; font-display: swap; unicode-range: U+0020-009F, U+00A1-024F, U+1E00-1EFF, U+2000-206F, U+2070-209F, U+20A0-20CF, U+2100-214F; }

  :root {
    --paper:    #EBEAE5;
    --paper-2:  #F2F1ED;
    --paper-d:  #DCDAD3;
    --ink:      #0B0B0B;
    --ink-2:    #1F1F1F;
    --forest:   #042615;
    --ash:      #A0A0A0;
    --ash-d:    #595959;
    --line:     rgba(11,11,11,.10);
    --line-d:   rgba(11,11,11,.18);

    --font-display: 'Disket Mono', monospace;
    --font-body:    'Gotham', 'Montserrat', system-ui, sans-serif;
    --font-mono:    'Disket Mono', ui-monospace, monospace;

    --header-h: 72px;
    --container: 1280px;
    --gutter: clamp(20px, 4vw, 56px);

    --ease-out: cubic-bezier(.22, 1, .36, 1);
    --dur-fast: 200ms;
    --dur-base: 360ms;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { -webkit-text-size-adjust: 100%; scroll-behavior: smooth; }
  body {
    font-family: var(--font-body);
    font-size: 15px; line-height: 1.6;
    color: var(--ink); background: var(--paper);
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
    overflow-x: hidden;
  }
  img, svg { display: block; max-width: 100%; }
  a { color: inherit; text-decoration: none; transition: color var(--dur-fast); }
  button { font: inherit; cursor: pointer; background: none; border: none; color: inherit; }
  ul { list-style: none; }
  ::selection { background: var(--forest); color: var(--paper); }
  :focus-visible { outline: 2px solid var(--forest); outline-offset: 4px; border-radius: 2px; }

  .skip-link {
    position: absolute; left: -9999px; top: 8px;
    padding: 10px 18px; background: var(--ink); color: var(--paper);
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .12em;
    border-radius: 999px; z-index: 9999;
  }
  .skip-link:focus { left: 16px; }

  .container {
    width: 100%; max-width: var(--container);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* ── Топо-паттерн (тонкий фон) ─────────────────────────── */
  .topo {
    position: absolute; inset: 0; z-index: 0;
    pointer-events: none; opacity: .35;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 600 400'><g fill='none' stroke='%230B0B0B' stroke-opacity='0.08' stroke-width='1'><path d='M0,180 Q150,140 300,170 T600,150'/><path d='M0,210 Q150,170 300,200 T600,180'/><path d='M0,240 Q150,200 300,230 T600,210'/><path d='M0,270 Q150,230 300,260 T600,240'/><path d='M0,300 Q150,260 300,290 T600,270'/><path d='M0,330 Q150,290 300,320 T600,300'/><path d='M-50,100 Q120,60 280,90 T620,70'/><path d='M-50,360 Q120,330 280,360 T620,340'/><path d='M0,60 Q200,20 400,50 T800,40'/></g></svg>");
    background-size: 800px 533px;
    background-repeat: repeat;
  }

  /* ── Утилиты ───────────────────────────────────────────── */
  .section-tag {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 13px; letter-spacing: .04em; text-transform: uppercase;
    color: var(--ink); display: inline-block;
    margin-bottom: 24px;
  }
  .section-tag::before {
    content: ''; display: inline-block;
    width: 28px; height: 1px; background: var(--ink);
    vertical-align: middle; margin-right: 12px;
  }
  .h-display {
    font-family: var(--font-body); font-weight: 700;
    font-size: clamp(36px, 5.5vw, 72px);
    line-height: 1.05; letter-spacing: -.02em; color: var(--ink);
  }
  .h-section {
    font-family: var(--font-body); font-weight: 700;
    font-size: clamp(32px, 4.5vw, 56px);
    line-height: 1.08; letter-spacing: -.02em; color: var(--ink);
  }
  .h-block {
    font-family: var(--font-body); font-weight: 700;
    font-size: clamp(20px, 2.4vw, 28px);
    line-height: 1.18; letter-spacing: -.01em; color: var(--ink);
  }
  .marker { display: inline-block; width: 14px; height: 14px; background: var(--forest); transform: rotate(45deg); margin-left: 10px; vertical-align: middle; }
  .body-text { color: var(--ink-2); font-size: 16px; line-height: 1.7; max-width: 60ch; }
  .lede { font-size: 17px; line-height: 1.55; color: var(--ink-2); max-width: 56ch; }

  .btn {
    display: inline-flex; align-items: center; justify-content: center;
    gap: 12px;
    padding: 16px 28px; min-height: 52px;
    font-family: var(--font-mono); font-weight: 700;
    font-size: 12px; letter-spacing: .14em; text-transform: uppercase;
    border: 1px solid var(--ink); border-radius: 999px;
    cursor: pointer; touch-action: manipulation;
    transition: background var(--dur-fast), color var(--dur-fast),
                border-color var(--dur-fast), transform var(--dur-fast);
  }
  .btn-primary { background: var(--ink); color: var(--paper); }
  .btn-primary:hover { background: var(--forest); border-color: var(--forest); }
  .btn-primary:active { transform: scale(.98); }
  .btn-ghost { background: transparent; color: var(--ink); }
  .btn-ghost:hover { background: var(--ink); color: var(--paper); }
  .btn .arrow {
    display: inline-block; width: 14px; height: 1px; background: currentColor;
    position: relative; transition: width var(--dur-fast);
  }
  .btn .arrow::after {
    content: ''; position: absolute; right: 0; top: -3px;
    width: 7px; height: 7px;
    border-top: 1px solid currentColor; border-right: 1px solid currentColor;
    transform: rotate(45deg);
  }
  .btn:hover .arrow { width: 22px; }

  /* ── Header ────────────────────────────────────────────── */
  .site-header {
    position: fixed; top: 0; left: 0; right: 0;
    z-index: 200;
    /* отступ под статус-бар iOS в PWA-режиме (notch / Dynamic Island) */
    padding-top: env(safe-area-inset-top);
    transition: background var(--dur-base), border-color var(--dur-base), backdrop-filter var(--dur-base);
    border-bottom: 1px solid transparent;
  }
  .site-header.is-solid {
    background: rgba(235, 234, 229, .85);
    backdrop-filter: blur(14px) saturate(140%);
    -webkit-backdrop-filter: blur(14px) saturate(140%);
    border-bottom-color: var(--line);
  }

  /* ── Header: inverted colors over dark hero (transparent state) ── */
  .site-header:not(.is-solid) .brand,
  .site-header:not(.is-solid) .brand-sub strong,
  .site-header:not(.is-solid) .primary-nav a,
  .site-header:not(.is-solid) .nav-phone,
  .site-header:not(.is-solid) .nav-book {
    color: var(--paper);
  }
  .site-header:not(.is-solid) .brand-sub {
    color: rgba(235, 234, 229, .7);
    border-left-color: rgba(235, 234, 229, .25);
  }
  .site-header:not(.is-solid) .primary-nav a:hover,
  .site-header:not(.is-solid) .nav-phone:hover {
    color: rgba(235, 234, 229, .7);
  }
  .site-header:not(.is-solid) .primary-nav a::after {
    background: var(--paper);
  }
  .site-header:not(.is-solid) .nav-book {
    border-color: rgba(235, 234, 229, .55);
  }
  .site-header:not(.is-solid) .nav-book:hover {
    background: var(--paper);
    color: var(--ink);
    border-color: var(--paper);
  }
  .site-header:not(.is-solid) .menu-toggle span {
    background: var(--paper);
  }

  .nav-row {
    display: flex; align-items: center; justify-content: space-between;
    gap: 24px; height: var(--header-h);
  }

  .brand {
    display: inline-flex; align-items: center; gap: 14px;
    flex-shrink: 0; color: var(--ink);
  }
  .brand-logo { width: 78px; height: auto; }
  .brand-logo svg { width: 100%; height: auto; }
  .brand-logo path { fill: currentColor; }
  .brand-sub {
    font-family: var(--font-mono);
    font-size: 9px; letter-spacing: .26em; text-transform: uppercase;
    color: var(--ash-d);
    border-left: 1px solid var(--line-d); padding-left: 12px; line-height: 1.3;
  }
  .brand-sub strong { display: block; color: var(--ink); font-weight: 700; }

  .primary-nav ul { display: flex; gap: 32px; }
  .primary-nav a {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
    color: var(--ink);
    padding: 8px 0; position: relative;
  }
  .primary-nav a::after {
    content: ''; position: absolute; left: 0; bottom: 4px;
    width: 100%; height: 1px; background: var(--forest);
    transform: scaleX(0); transform-origin: left;
    transition: transform var(--dur-base) var(--ease-out);
  }
  .primary-nav a:hover { color: var(--forest); }
  .primary-nav a:hover::after { transform: scaleX(1); }

  .nav-cta { display: flex; align-items: center; gap: 14px; }
  .nav-phone {
    font-family: var(--font-mono);
    font-size: 12px; color: var(--ink);
    font-variant-numeric: tabular-nums; letter-spacing: .04em;
  }
  .nav-phone:hover { color: var(--forest); }
  .nav-book {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
    padding: 10px 18px; min-height: 40px;
    border: 1px solid var(--ink); border-radius: 999px;
    color: var(--ink); display: inline-flex; align-items: center;
    transition: background var(--dur-fast), color var(--dur-fast);
  }
  .nav-book:hover { background: var(--ink); color: var(--paper); }

  .menu-toggle {
    display: none; width: 44px; height: 44px;
    flex-direction: column; justify-content: center; align-items: center;
    gap: 5px;
  }
  .menu-toggle span {
    display: block; height: 1.5px; width: 22px; background: var(--ink);
    transition: transform var(--dur-base), opacity var(--dur-fast);
  }
  .menu-toggle[aria-expanded="true"] span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .menu-toggle[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .menu-toggle[aria-expanded="true"] span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  .mobile-overlay {
    position: fixed; inset: 0; z-index: 190;
    background: var(--paper);
    padding: calc(var(--header-h) + env(safe-area-inset-top) + 32px) var(--gutter) var(--gutter);
    opacity: 0; pointer-events: none;
    transition: opacity var(--dur-base);
    display: flex; flex-direction: column; justify-content: space-between;
  }
  .mobile-overlay.is-open { opacity: 1; pointer-events: auto; }
  .mobile-overlay nav ul { display: grid; gap: 4px; }
  .mobile-overlay nav a {
    display: block; padding: 14px 0;
    font-family: var(--font-body); font-weight: 700;
    font-size: clamp(28px, 7vw, 44px);
    letter-spacing: -.02em; line-height: 1;
    color: var(--ink); border-bottom: 1px solid var(--line);
  }
  .mobile-overlay nav a:hover { color: var(--forest); }
  .mobile-foot { display: flex; flex-direction: column; gap: 16px; padding-top: 32px; }

  @media (max-width: 920px) {
    .primary-nav, .nav-phone, .nav-book { display: none; }
    .menu-toggle { display: flex; }
  }

  /* ── HERO (video cover, как в оригинале) ───────────────── */
  .hero {
    position: relative; min-height: 100dvh;
    overflow: hidden;
    display: flex; flex-direction: column;
    background: var(--ink); color: var(--paper);
  }
  .hero-bg {
    position: absolute; inset: 0; z-index: 0;
    background:
      radial-gradient(ellipse 60% 60% at 30% 30%, rgba(4,38,21,.55) 0%, transparent 60%),
      radial-gradient(ellipse 50% 70% at 80% 80%, rgba(160,160,160,.10) 0%, transparent 60%),
      linear-gradient(135deg, #0d0d0d 0%, var(--ink) 50%, #050505 100%);
  }
  .hero-bg::after {
    content: ''; position: absolute; inset: 0;
    background-image:
      linear-gradient(to right,  rgba(235,234,229,.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(235,234,229,.04) 1px, transparent 1px);
    background-size: 80px 80px;
    mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
    -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 80%);
  }

  .hero-grid {
    flex: 1; position: relative; z-index: 1;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding-top: calc(var(--header-h) + env(safe-area-inset-top) + 16px);
  }

  .hero-meta {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0 var(--gutter); height: 56px;
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: .16em; text-transform: uppercase;
    color: rgba(235,234,229,.65);
  }
  .hero-meta .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--forest); display: inline-block; margin-inline: 6px; }
  .hero-meta .l, .hero-meta .r { display: inline-flex; align-items: center; gap: 12px; }
  @media (max-width: 720px) { .hero-meta { font-size: 9px; } .hero-meta .meta-hide { display: none; } }

  .hero-stage {
    position: relative;
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    padding: 32px var(--gutter);
    text-align: center;
    gap: 28px;
  }
  .hero-mark {
    width: min(78vw, 880px);
    color: var(--paper);
    position: relative;
  }
  .hero-mark svg { width: 100%; height: auto; }
  .hero-mark path { fill: currentColor; }
  .hero-mark::after {
    content: 'moscow';
    position: absolute; bottom: -22px; left: 50%; transform: translateX(-50%);
    font-family: var(--font-mono); font-size: clamp(11px, 1.2vw, 14px);
    letter-spacing: .42em; color: var(--paper); text-transform: lowercase;
  }
  .hero-mark::before {
    content: '™';
    position: absolute; top: 8%; right: -2%;
    font-family: var(--font-mono); font-size: clamp(10px, 1vw, 14px);
    color: var(--paper);
  }

  .hero-tag {
    margin-top: 32px;
    font-family: var(--font-body); font-weight: 400;
    font-size: clamp(18px, 1.8vw, 22px); line-height: 1.4;
    color: rgba(235,234,229,.78); letter-spacing: -.005em;
    max-width: 36ch;
    text-align: center;
    text-align-last: center;
    text-wrap: balance;
    word-spacing: normal;
  }

  /* Видео-плейсхолдер плеера, как в оригинале */
  .hero-play {
    position: relative; margin-top: 16px;
    display: inline-flex; align-items: center; justify-content: center;
    width: 78px; height: 78px;
    border-radius: 50%; border: 1px solid var(--paper);
    background: rgba(235,234,229,.06);
    color: var(--paper);
    cursor: pointer; backdrop-filter: blur(4px);
    transition: background var(--dur-fast), transform var(--dur-fast), border-color var(--dur-fast);
  }
  .hero-play::after {
    content: ''; display: block;
    width: 0; height: 0;
    border-left: 14px solid var(--paper);
    border-top: 9px solid transparent; border-bottom: 9px solid transparent;
    margin-left: 4px;
  }
  .hero-play:hover { background: var(--paper); border-color: var(--paper); transform: scale(1.05); }
  .hero-play:hover::after { border-left-color: var(--ink); }
  .hero-play-label {
    font-family: var(--font-mono); font-size: 10px; letter-spacing: .2em;
    text-transform: uppercase; color: rgba(235,234,229,.5);
    margin-top: 12px; display: block;
  }

  .hero-foot {
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 16px;
    padding: 22px var(--gutter);
    border-top: 1px solid rgba(235,234,229,.18);
    background: var(--ink); position: relative; z-index: 2;
  }
  .hero-pill {
    display: inline-flex; align-items: center; gap: 10px;
    padding: 9px 18px;
    border: 1px solid rgba(235,234,229,.45); border-radius: 999px;
    font-family: var(--font-mono); font-weight: 700;
    font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
    color: var(--paper);
  }
  .hero-cta {
    display: inline-flex; align-items: center; gap: 14px;
    padding: 14px 26px; min-height: 50px;
    background: var(--paper); color: var(--ink);
    border-radius: 999px;
    font-family: var(--font-mono); font-weight: 700;
    font-size: 12px; letter-spacing: .14em; text-transform: uppercase;
    transition: background var(--dur-fast);
  }
  .hero-cta:hover { background: var(--forest); color: var(--paper); }
  .hero-cta .arrow { display: inline-block; width: 16px; height: 1px; background: currentColor; position: relative; transition: width var(--dur-fast); }
  .hero-cta .arrow::after {
    content: ''; position: absolute; right: 0; top: -3.5px;
    width: 8px; height: 8px;
    border-top: 1px solid currentColor; border-right: 1px solid currentColor;
    transform: rotate(45deg);
  }
  .hero-cta:hover .arrow { width: 24px; }
  .hero-secondary { font-family: var(--font-mono); font-size: 11px; letter-spacing: .14em; text-transform: uppercase; color: rgba(235,234,229,.65); }

  /* fade-in логотипа */
  .hero-mark { opacity: 0; transform: translateY(20px); transition: opacity 1.2s var(--ease-out), transform 1.2s var(--ease-out); }
  .hero-mark.is-in { opacity: 1; transform: none; }

  /* ── Section base ──────────────────────────────────────── */
  section { position: relative; }
  .section-pad { padding-block: clamp(72px, 9vw, 128px); }
  .section-content { position: relative; z-index: 1; }

  /* ── СЕКЦИЯ: УСЛУГИ ────────────────────────────────────── */
  .services { background: var(--paper); border-top: 1px solid var(--ink); }
  .services-head {
    display: grid; grid-template-columns: 1fr; gap: 28px;
    align-items: start;
    margin-bottom: 64px;
  }
  @media (min-width: 920px) {
    .services-head { grid-template-columns: 7fr 5fr; gap: 64px; }
    /* Лид справа сидит на одной верхней линии с заголовком —
       читается как редакционный sidebar к большому «Услуги», без «висячих» строк. */
    .services-head > .lede {
      text-align: right;
      align-self: start;
      margin: 0 0 0 auto;
      padding-top: 10px;
      max-width: 44ch;
      text-wrap: balance;
    }
  }

  .services-cats {
    display: grid; gap: 56px;
  }
  @media (min-width: 1100px) {
    .services-cats {
      grid-template-columns: 1.3fr 1fr 1fr; gap: 48px;
      align-items: stretch;
    }
    /* Каждая колонка — flex column, чтобы внутренний список мог растягиваться по высоте */
    .services-cats > div { display: flex; flex-direction: column; }
  }

  .services-cat-head {
    display: flex; align-items: baseline; justify-content: space-between;
    border-bottom: 1px solid var(--ink);
    padding-bottom: 14px; margin-bottom: 8px;
  }
  .services-cat-name {
    font-family: var(--font-body); font-weight: 700;
    font-size: 18px; color: var(--ink);
    letter-spacing: -.005em;
  }
  .services-cat-tag {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 11px; letter-spacing: .14em; text-transform: uppercase;
    color: var(--ash-d);
  }

  .price-list { display: flex; flex-direction: column; gap: 0; }
  /* На десктопе строки прайса равномерно распределяются по высоте колонки —
     обе категории (Основные/Дополнительные) выравниваются с Комплексами по высоте. */
  @media (min-width: 1100px) {
    .price-list { flex: 1; justify-content: space-between; }
  }
  .price-row {
    display: grid; grid-template-columns: 1fr auto;
    align-items: baseline;
    gap: 16px;
    padding: 16px 8px;
    margin-inline: -8px;
    border-bottom: 1px solid var(--line);
    border-radius: 6px;
    transition: background var(--dur-fast);
    cursor: default;
  }
  .price-row:hover { background: var(--paper-2); }
  .price-row .name {
    font-family: var(--font-body); font-weight: 500;
    font-size: 15px; color: var(--ink); line-height: 1.35;
  }
  .price-row .price {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 14px; color: var(--ink);
    font-variant-numeric: tabular-nums; letter-spacing: .04em;
    white-space: nowrap;
  }

  .complex-list { display: flex; flex-direction: column; gap: 12px; }
  /* На десктопе каждая карточка Комплекса тянется на равную долю высоты колонки.
     Контент в карточке центрируется по вертикали — без пустот между блоками. */
  @media (min-width: 1100px) {
    .complex-list { flex: 1; gap: 14px; }
    .complex-list > .complex { flex: 1; align-content: center; }
  }
  .complex {
    background: var(--paper-2);
    border: 1px solid var(--line-d);
    border-radius: 16px;
    padding: 22px 24px;
    display: grid; grid-template-columns: 1fr auto;
    align-items: baseline; gap: 16px;
    transition: border-color var(--dur-fast), background var(--dur-fast), color var(--dur-fast);
  }
  .complex:hover { background: var(--ink); border-color: var(--ink); color: var(--paper); }
  .complex:hover .complex-name { color: var(--paper); }
  .complex:hover .complex-price { color: var(--paper); }
  .complex-name {
    font-family: var(--font-body); font-weight: 700;
    font-size: 17px; letter-spacing: -.005em;
    color: var(--ink);
  }
  .complex-price {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 15px; color: var(--ink);
    font-variant-numeric: tabular-nums; letter-spacing: .04em;
    white-space: nowrap;
  }
  .complex-note {
    grid-column: 1 / -1;
    font-family: var(--font-body); font-size: 13px;
    color: var(--ash-d); line-height: 1.5;
  }
  .complex:hover .complex-note { color: rgba(235,234,229,.55); }

  .services-foot {
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 24px;
    margin-top: 56px;
    padding-top: 28px; border-top: 1px solid var(--line-d);
  }
  .services-foot-note {
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ash-d); letter-spacing: .12em; text-transform: uppercase;
  }

  /* ── СЕКЦИЯ: КОМАНДА ───────────────────────────────────── */
  .team { background: var(--paper); border-top: 1px solid var(--ink); position: relative; }
  .team-head {
    display: grid; grid-template-columns: 1fr; gap: 28px;
    align-items: end;
    margin-bottom: 56px;
  }
  @media (min-width: 920px) {
    .team-head { grid-template-columns: 7fr 5fr; gap: 64px; }
  }

  .team-grid {
    display: grid; grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 720px) { .team-grid { grid-template-columns: 1fr 1fr; } }
  @media (min-width: 1100px) { .team-grid { grid-template-columns: repeat(3, 1fr); } }

  .master {
    background: var(--paper-2);
    border: 1px solid var(--line-d);
    border-radius: 24px;
    padding: 22px;
    display: grid;
    grid-template-rows: auto auto auto auto auto;
    gap: 16px;
    align-self: start;
    transition: border-color var(--dur-base), background var(--dur-base);
  }
  .master:hover { border-color: var(--ink); background: var(--paper); }

  .master-head {
    display: flex; justify-content: space-between; align-items: center;
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: .14em; text-transform: uppercase;
    color: var(--ash-d);
  }
  .master-head .num { color: var(--forest); font-weight: 700; }
  .master-head .role { font-weight: 500; color: var(--ash-d); }

  .master-photo {
    height: 280px;
    background:
      radial-gradient(ellipse at 30% 25%, rgba(160,160,160,.18), transparent 50%),
      linear-gradient(135deg, var(--ink-2) 0%, var(--ink) 60%, #050505 100%);
    border-radius: 16px;
    overflow: hidden;
    position: relative;
  }
  .master-photo::after {
    content: attr(data-init);
    position: absolute; left: 50%; top: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display); font-weight: 700;
    font-size: 48px; letter-spacing: .04em;
    color: rgba(235,234,229,.18);
  }
  .master-photo img {
    position: absolute; inset: 0;
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .master-photo:has(img)::after { display: none; }

  .master-name {
    font-family: var(--font-body); font-weight: 700;
    font-size: 20px; line-height: 1.15; letter-spacing: -.01em;
    color: var(--ink);
    min-height: 46px;
  }
  .master-bio {
    font-family: var(--font-body); font-size: 13.5px; line-height: 1.55;
    color: var(--ink-2);
    /* Раньше тут был -webkit-line-clamp:5 — обрезалось био у спикеров
       на десктопе в средней ширине окна. Теперь карточка растёт до
       полного текста, grid выравнивает их по высоте самой длинной. */
  }
  .master-tags {
    display: flex; flex-wrap: wrap; gap: 6px;
    min-height: 28px;
  }
  .master-tag {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 10px; letter-spacing: .12em; text-transform: uppercase;
    color: var(--ink); background: var(--paper);
    border: 1px solid var(--line-d); border-radius: 999px;
    padding: 5px 10px;
  }

  /* ── CTA-блок «ЗАПИСАТЬСЯ» (тёмный) ────────────────────── */
  .cta {
    background: var(--ink); color: var(--paper);
    border-top: 1px solid var(--ink);
    overflow: hidden; position: relative;
  }
  .cta .topo { opacity: .12; filter: invert(1); }
  .cta-inner {
    padding-block: clamp(72px, 9vw, 128px);
    text-align: center;
    position: relative; z-index: 1;
  }
  .cta-tag {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 12px; letter-spacing: .22em; text-transform: uppercase;
    color: rgba(235,234,229,.55);
    margin-bottom: 24px;
  }
  .cta-title {
    font-family: var(--font-body); font-weight: 700;
    font-size: clamp(40px, 8vw, 96px); line-height: 1;
    letter-spacing: -.025em;
    color: var(--paper);
  }
  .cta-sub {
    margin-top: 24px;
    font-family: var(--font-body); font-size: clamp(15px, 1.6vw, 18px);
    line-height: 1.55; color: rgba(235,234,229,.7);
    max-width: 50ch; margin-inline: auto;
  }
  .cta-buttons {
    margin-top: 40px;
    display: inline-flex; flex-wrap: wrap; justify-content: center; gap: 14px;
  }
  .cta .btn {
    border-color: var(--paper); color: var(--paper);
  }
  .cta .btn-primary { background: var(--paper); color: var(--ink); }
  .cta .btn-primary:hover { background: var(--forest); border-color: var(--forest); color: var(--paper); }
  .cta .btn-ghost:hover { background: var(--paper); color: var(--ink); }

  /* ── СЕКЦИЯ: КОНТАКТЫ ──────────────────────────────────── */
  .contacts { background: var(--paper); border-top: 1px solid var(--ink); }
  .contacts-grid {
    display: grid; grid-template-columns: 1fr; gap: 48px;
    align-items: start;
  }
  @media (min-width: 920px) {
    .contacts-grid { grid-template-columns: 5fr 7fr; gap: 80px; }
  }

  .contacts-list {
    display: grid; gap: 0;
    border-top: 1px solid var(--ink);
    margin-top: 32px;
  }
  .contacts-list-item {
    display: grid; grid-template-columns: 130px 1fr;
    gap: 24px; padding: 20px 0;
    border-bottom: 1px solid var(--line-d);
    align-items: baseline;
  }
  .contacts-list-item dt {
    font-family: var(--font-mono); font-size: 11px;
    letter-spacing: .14em; text-transform: uppercase;
    color: var(--ash-d);
  }
  .contacts-list-item dd {
    font-family: var(--font-body);
    font-size: 17px; color: var(--ink); line-height: 1.45;
  }
  .contacts-list-item dd a { color: var(--ink); border-bottom: 1px solid var(--line-d); padding-bottom: 1px; }
  .contacts-list-item dd a:hover { color: var(--forest); border-color: var(--forest); }
  .contacts-list-item dd .muted { color: var(--ash-d); display: block; font-size: 14px; margin-top: 2px; }
  .contacts-list-item dd .phone {
    font-family: var(--font-mono); font-weight: 700;
    font-size: clamp(16px, 5.2vw, 22px);
    letter-spacing: .04em;
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
    display: inline-block;
    transition: color var(--dur-fast);
  }
  .contacts-list-item dd a.phone:hover { color: var(--forest); }

  .map-frame {
    aspect-ratio: 4 / 3;
    border: 1px solid var(--line-d);
    border-radius: 24px;
    overflow: hidden; position: relative;
    background: var(--paper-2);
  }
  .map-frame iframe {
    position: absolute; top: 0; left: 0; right: 0;
    width: 100%; height: calc(100% + 80px);
    border: none; display: block;
  }
  .map-link {
    position: absolute; left: 16px; bottom: 16px; z-index: 2;
    font-family: var(--font-mono); font-weight: 700;
    font-size: 12px; letter-spacing: .14em; text-transform: uppercase;
    color: var(--ink); background: var(--paper);
    padding: 11px 28px; border-radius: 999px;
    border: 1.5px solid var(--ink);
    transition: background var(--dur-fast), color var(--dur-fast);
    white-space: nowrap;
  }
  .map-link:hover { background: var(--ink); color: var(--paper); }

  /* ── СЕКЦИЯ: ИНТЕРЬЕР ──────────────────────────────────── */
  .interior { background: var(--paper); border-top: 1px solid var(--ink); }

  /* Шапка секции остаётся в стандартном контейнере, а сетка кадров —
     в расширенном до 1600px (editorial-эффект, без полного 100vw). */
  .interior-wide {
    width: 100%;
    max-width: 1600px;
    margin-inline: auto;
    padding-inline: var(--gutter);
    margin-top: 64px;
  }

  .interior-grid {
    display: grid; grid-template-columns: 1fr; gap: 16px;
  }
  @media (min-width: 760px) {
    .interior-grid { grid-template-columns: 1fr 1fr; gap: 24px; }
    .interior-grid > .span-2 { grid-column: 1 / -1; }
  }

  .interior-figure {
    position: relative; overflow: hidden;
    border-radius: 20px;
    background: var(--paper-2);
    aspect-ratio: 5 / 4;
    margin: 0;
  }
  .interior-figure.wide { aspect-ratio: 21 / 9; }

  .interior-figure img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
    transition: transform var(--dur-slow) ease;
  }
  .interior-figure:hover img { transform: scale(1.04); }

  .interior-figure figcaption {
    position: absolute; left: 20px; bottom: 20px;
    font-family: var(--font-mono); font-weight: 700;
    font-size: 11px; letter-spacing: .22em; text-transform: uppercase;
    color: var(--paper);
    background: rgba(20, 22, 18, .55);
    padding: 8px 14px; border-radius: 999px;
    backdrop-filter: blur(8px);
  }

  /* ── СЕКЦИЯ: ПАРТНЁРЫ ──────────────────────────────────── */
  .partners { background: var(--paper); border-top: 1px solid var(--ink); }
  .partners-grid {
    display: grid; grid-template-columns: 1fr;
    margin-top: 56px;
    border-top: 1px solid var(--line-d);
  }
  @media (min-width: 760px) { .partners-grid { grid-template-columns: 1fr 1fr; } }

  .partner-row {
    display: flex; align-items: center; gap: 36px;
    padding: 48px 0;
    border-bottom: 1px solid var(--line-d);
  }
  @media (min-width: 760px) {
    .partner-row:nth-child(odd)  { padding-right: 56px; border-right: 1px solid var(--line-d); }
    .partner-row:nth-child(even) { padding-left: 56px; }
    /* Нижнюю линию убираем ТОЛЬКО у фактически последней строки.
       Раньше тут было :nth-last-child(-n+2), но при нечётном количестве
       партнёров (9-й full-width-акцент) это случайно скрывало линию у
       предпоследнего — образуя «дыру» между парой и акцентной строкой. */
    .partner-row:last-child { border-bottom: none; }
    /* Если последний партнёр оказался один в строке слева (без правого
       соседа в обычной grid-сетке) — у него убираем боковую линию. */
    .partner-row:last-child:nth-child(odd) { border-right: none; }
    /* Force-линия для предпоследних двух партнёров (та пара что
       непосредственно над акцентной full-width строкой) — на случай
       если какой-то предыдущий браузерный кэш или specificity их
       перебивает. */
    .partner-row:nth-last-child(2),
    .partner-row:nth-last-child(3) { border-bottom: 1px solid var(--line-d); }
  }

  .partner-logo {
    flex-shrink: 0; width: 150px; height: 80px;
    display: flex; align-items: center; justify-content: center;
    color: var(--ink);
  }
  /* Все логотипы — единый PNG-формат 600x300 canvas с равным padding.
     При object-fit: contain все 9 партнёров получают одинаковую видимую
     высоту, выровнены по центру. filter:brightness(0) обеспечивает
     общий монохром поверх любого источника. */
  .partner-logo-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center center;
    filter: brightness(0);
    opacity: .88;
    transition: opacity .2s;
  }
  .partner-row:hover .partner-logo-img { opacity: 1; }
  /* Bold-текст для BETONE — повторяет brand-плакатный стиль. */
  .logo-betone {
    font-family: var(--font-body); font-weight: 900;
    font-size: 32px; letter-spacing: -.03em; line-height: 1;
    color: var(--ink);
  }
  /* Fallback для редких text-логотипов (если кто-то останется без файла). */
  .logo-text {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 16px; letter-spacing: .08em; line-height: 1;
    color: var(--ink); text-transform: uppercase;
  }

  /* Нечётный последний партнёр (9-й) занимает всю строку как акцент. */
  .partners-grid .partner-row:last-child:nth-child(odd) {
    grid-column: 1 / -1;
    padding-right: 0;
    border-right: none;
    justify-content: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .partner-text {
    flex: 1; font-family: var(--font-body);
    font-size: 14px; line-height: 1.65; color: var(--ink-2);
  }

  /* ── Footer ────────────────────────────────────────────── */
  .site-footer {
    background: var(--paper);
    padding-top: clamp(64px, 8vw, 96px);
    padding-bottom: 28px;
    border-top: 1px solid var(--ink);
    position: relative; overflow: hidden;
  }
  .site-footer .topo { opacity: .25; }

  .footer-mark {
    width: clamp(220px, 50vw, 600px);
    color: var(--ink);
    margin: 0 auto 56px;
    position: relative;
  }
  .footer-mark svg { width: 100%; height: auto; }
  .footer-mark path { fill: currentColor; }
  .footer-mark::after {
    content: 'moscow ™';
    position: absolute; bottom: -20px; left: 50%; transform: translateX(-50%);
    font-family: var(--font-mono); font-size: 11px; letter-spacing: .42em;
    color: var(--ink); text-transform: lowercase;
  }

  .footer-grid {
    display: grid; grid-template-columns: 1fr; gap: 40px;
    padding-block: 48px;
    border-top: 1px solid var(--ink); border-bottom: 1px solid var(--ink);
    position: relative; z-index: 1;
  }
  @media (min-width: 760px) {
    .footer-grid { grid-template-columns: 2fr 1fr 1fr 1.4fr; gap: 48px; }
  }

  .footer-col h4 {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
    color: var(--ash-d);
    margin-bottom: 18px;
  }
  .footer-col ul { display: grid; gap: 10px; }
  nav.footer-col ul { columns: 2; column-gap: 20px; display: block; }
  nav.footer-col ul li { margin-bottom: 10px; break-inside: avoid; }
  .footer-col a { font-size: 14px; color: var(--ink); }
  .footer-col a:hover { color: var(--forest); }

  .footer-pitch {
    font-family: var(--font-body); font-weight: 700;
    font-size: clamp(18px, 1.7vw, 22px); line-height: 1.25;
    color: var(--ink); letter-spacing: -.01em;
    max-width: 22ch; margin-bottom: 20px;
  }
  .footer-phone {
    display: block;
    font-family: var(--font-mono); font-weight: 700;
    font-size: 18px; color: var(--ink);
    font-variant-numeric: tabular-nums; letter-spacing: .04em;
    margin-bottom: 8px;
  }
  .footer-phone:hover { color: var(--forest); }
  .footer-email { display: block; font-size: 14px; color: var(--ink-2); margin-bottom: 22px; }

  .footer-social { display: flex; flex-wrap: wrap; gap: 8px; }
  .footer-social a {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 10px; letter-spacing: .14em; text-transform: uppercase;
    color: var(--ink);
    border: 1px solid var(--ink); border-radius: 999px;
    padding: 7px 14px;
    transition: background var(--dur-fast), color var(--dur-fast);
  }
  .footer-social a:hover { background: var(--ink); color: var(--paper); }

  .footer-bottom {
    display: flex; justify-content: space-between; align-items: center;
    flex-wrap: wrap; gap: 16px;
    padding-top: 24px;
    font-family: var(--font-mono); font-size: 11px;
    color: var(--ash-d); letter-spacing: .12em; text-transform: uppercase;
  }

  /* ── Sticky mobile CTA ─────────────────────────────────── */
  .sticky-cta {
    display: none;
    position: fixed; bottom: 0; left: 0; right: 0;
    z-index: 150; padding: 12px 16px env(safe-area-inset-bottom, 12px);
    background: rgba(235, 234, 229, .92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-top: 1px solid var(--line-d);
  }
  .sticky-cta .btn { width: 100%; }
  .sticky-cta .btn-primary {
    background: #E86A30;
    border-color: #E86A30;
    color: #fff;
    font-size: 12px;
    padding: 16px 22px;
    box-shadow: 0 8px 24px rgba(232, 106, 48, .4), 0 2px 6px rgba(232, 106, 48, .25);
    letter-spacing: .18em;
  }
  .sticky-cta .btn-primary:hover,
  .sticky-cta .btn-primary:active {
    background: #D55518;
    border-color: #D55518;
    box-shadow: 0 6px 18px rgba(213, 85, 24, .5);
  }
  @media (max-width: 720px) {
    .sticky-cta.is-shown { display: block; }
    .site-footer { padding-bottom: 88px; }
  }

  /* ── Inline hero video player «Стиль» ───────────────────── */
  .hero-video {
    width: min(92vw, 1040px);
    margin: 8px auto 0;
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    background: #000;
    border: 1px solid rgba(235,234,229,.18);
    box-shadow: 0 30px 80px rgba(0,0,0,.45);
    opacity: 0;
    transform: translateY(12px) scale(.98);
    transition: opacity .4s var(--ease-out), transform .4s var(--ease-out);
  }
  .hero-video[hidden] { display: none; }
  .hero-video.is-open { opacity: 1; transform: none; }
  .hero-video__media {
    display: block;
    width: 100%;
    height: auto;
    max-height: 62vh;
    background: #000;
    object-fit: contain;
  }
  .hero-video__close {
    position: absolute;
    top: 12px; right: 12px;
    width: 38px; height: 38px;
    display: inline-flex; align-items: center; justify-content: center;
    background: rgba(8,10,9,.6);
    color: var(--paper);
    border: 1px solid rgba(235,234,229,.35);
    border-radius: 50%;
    font-size: 20px; line-height: 1;
    cursor: pointer;
    backdrop-filter: blur(6px);
    transition: background var(--dur-fast), color var(--dur-fast), transform var(--dur-fast), border-color var(--dur-fast);
    z-index: 3;
  }
  .hero-video__close:hover {
    background: var(--paper);
    color: var(--ink);
    border-color: var(--paper);
    transform: scale(1.05);
  }
  .hero-video__close:focus-visible {
    outline: 2px solid var(--paper);
    outline-offset: 2px;
  }
  /* When video is playing inline, fade out launch button + label */
  .hero-stage.is-playing .hero-play,
  .hero-stage.is-playing .hero-play-label {
    display: none;
  }

  /* ── Reveal ────────────────────────────────────────────── */
  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 1s var(--ease-out), transform 1s var(--ease-out); }
  .reveal.is-in { opacity: 1; transform: none; }
  .reveal-stagger > * { opacity: 0; transform: translateY(18px); transition: opacity .8s var(--ease-out), transform .8s var(--ease-out); }
  .reveal-stagger.is-in > * { opacity: 1; transform: none; }
  .reveal-stagger.is-in > *:nth-child(1) { transition-delay: .04s; }
  .reveal-stagger.is-in > *:nth-child(2) { transition-delay: .10s; }
  .reveal-stagger.is-in > *:nth-child(3) { transition-delay: .16s; }
  .reveal-stagger.is-in > *:nth-child(4) { transition-delay: .22s; }
  .reveal-stagger.is-in > *:nth-child(5) { transition-delay: .28s; }
  .reveal-stagger.is-in > *:nth-child(6) { transition-delay: .34s; }
  .reveal-stagger.is-in > *:nth-child(7) { transition-delay: .40s; }
  .reveal-stagger.is-in > *:nth-child(8) { transition-delay: .46s; }
  .reveal-stagger.is-in > *:nth-child(9) { transition-delay: .52s; }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: .001ms !important;
      transition-duration: .001ms !important;
      scroll-behavior: auto !important;
    }
    .reveal, .reveal-stagger > *, .hero-mark { opacity: 1 !important; transform: none !important; }
  }
  </style>
</head>

