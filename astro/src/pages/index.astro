  <!-- Sticky mobile CTA -->
  <div class="sticky-cta" id="stickyCta" aria-hidden="true">
    <a href="#cta" class="btn btn-primary">Записаться <span class="arrow"></span></a>
  </div>

  <script>
  (function () {
    'use strict';

    const $  = (s, c = document) => c.querySelector(s);
    const $$ = (s, c = document) => Array.from(c.querySelectorAll(s));
    const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* Header solid + sticky CTA */
    const header = $('#site-header');
    const sticky = $('#stickyCta');
    const onScroll = () => {
      header && header.classList.toggle('is-solid', window.scrollY > 32);
      sticky && sticky.classList.toggle('is-shown', window.scrollY > window.innerHeight * 0.6);
    };
    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    /* Inline hero video: открыть/закрыть прямо внутри hero-секции */
    const heroVideo = $('#heroVideo');
    const heroStage = heroVideo ? heroVideo.closest('.hero-stage') : null;
    const heroVideoEl = heroVideo ? heroVideo.querySelector('video') : null;

    const openHeroVideo = () => {
      if (!heroVideo || !heroVideoEl || !heroStage) return;
      heroStage.classList.add('is-playing');
      heroVideo.hidden = false;
      // force reflow so the transition runs
      void heroVideo.offsetWidth;
      heroVideo.classList.add('is-open');
      heroVideoEl.play().catch(() => {});
      // Bring the player into view if it overflows the viewport
      requestAnimationFrame(() => {
        heroVideo.scrollIntoView({ behavior: prefersReduced ? 'auto' : 'smooth', block: 'center' });
      });
    };

    const closeHeroVideo = () => {
      if (!heroVideo || !heroVideoEl || !heroStage) return;
      heroVideoEl.pause();
      heroVideoEl.currentTime = 0;
      heroVideo.classList.remove('is-open');
      const finalize = () => {
        heroVideo.hidden = true;
        heroStage.classList.remove('is-playing');
      };
      if (prefersReduced) finalize();
      else setTimeout(finalize, 400);
    };

    $$('[data-video-open]').forEach(b => b.addEventListener('click', openHeroVideo));
    $$('[data-video-close]').forEach(b => b.addEventListener('click', closeHeroVideo));

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && heroVideo && !heroVideo.hidden) closeHeroVideo();
    });

    /* Mobile menu */
    const toggle  = $('.menu-toggle');
    const overlay = $('#mobile-nav');
    if (toggle && overlay) {
      const closeMenu = () => {
        toggle.setAttribute('aria-expanded', 'false');
        overlay.classList.remove('is-open');
        overlay.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      };
      const openMenu = () => {
        toggle.setAttribute('aria-expanded', 'true');
        overlay.classList.add('is-open');
        overlay.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
      };
      toggle.addEventListener('click', () => {
        toggle.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
      });
      overlay.addEventListener('click', e => {
        if (e.target.tagName === 'A') closeMenu();
      });
      window.addEventListener('keydown', e => {
        if (e.key === 'Escape' && toggle.getAttribute('aria-expanded') === 'true') closeMenu();
      });
    }

    /* Hero mark fade-in */
    const heroMark = $('.hero-mark');
    if (heroMark) {
      if (prefersReduced) heroMark.classList.add('is-in');
      else requestAnimationFrame(() => requestAnimationFrame(() => heroMark.classList.add('is-in')));
    }

    /* Reveal on scroll */
    if ('IntersectionObserver' in window && !prefersReduced) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in');
            io.unobserve(entry.target);
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -8% 0px' });
      $$('.reveal, .reveal-stagger').forEach(el => io.observe(el));
    } else {
      $$('.reveal, .reveal-stagger').forEach(el => el.classList.add('is-in'));
    }

    /* Smooth anchor scroll with header offset */
    $$('a[href^="#"]').forEach(a => {
      a.addEventListener('click', e => {
        const id = a.getAttribute('href');
        if (id.length < 2) return;
        const target = document.querySelector(id);
        if (!target) return;
        e.preventDefault();
        const top = target.getBoundingClientRect().top + window.scrollY - 24;
        window.scrollTo({ top, behavior: prefersReduced ? 'auto' : 'smooth' });
      });
    });

  })();
  </script>

  <CookieBanner />
</body>
