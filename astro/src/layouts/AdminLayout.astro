---
import services from '../content/services.json';
import team from '../content/team.json';
import works from '../content/works.json';
import partners from '../content/partners.json';

type CollectionId = 'services' | 'team' | 'contacts' | 'works' | 'partners' | 'site';

interface Props {
  pageTitle?: string;
  activeCollection?: CollectionId;
}

const { pageTitle = 'CMS', activeCollection } = Astro.props;

const counts = {
  services: services.categories.reduce((s, c) => s + c.items.length, 0),
  team: team.masters.length,
  contacts: 4,
  works: works.items.length,
  partners: partners.partners.length,
  site: 1,
};

const collections: Array<{ id: CollectionId; label: string; count: number; }> = [
  { id: 'services', label: 'Услуги', count: counts.services },
  { id: 'team', label: 'Команда', count: counts.team },
  { id: 'works', label: 'Работы', count: counts.works },
  { id: 'partners', label: 'Партнёры', count: counts.partners },
  { id: 'contacts', label: 'Контакты', count: counts.contacts },
  { id: 'site', label: 'Сайт', count: counts.site },
];
---
<!doctype html>
<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{pageTitle} · TYPE CMS</title>
  <link rel="icon" type="image/svg+xml" href="/assets/type-mark.svg" />
</head>
<body class="cms-body">

<div class="cms">

  <header class="topbar">
    <button type="button" class="mobile-menu-btn" data-toggle-sidebar aria-label="Меню" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
    <div class="brand">
      <span class="brand-mark">TYPE · CMS</span>
      <span class="brand-sub">est. 2024 · admin</span>
    </div>
    <div class="user-meta">
      <span class="user-meta__role"><strong>admin</strong> · менеджер</span>
      <a class="logout" href="/admin/logout">Выйти</a>
    </div>
  </header>

  <div class="sidebar-backdrop" data-sidebar-backdrop hidden></div>

  <aside class="sidebar">
    <h4>Коллекции</h4>
    <ul>
      {collections.map(c => (
        <li>
          <a href={`/admin/${c.id}`} class={activeCollection === c.id ? 'active' : ''}>
            {c.label}
            <span class="count">{String(c.count).padStart(2, '0')}</span>
          </a>
        </li>
      ))}
    </ul>

    <div class="sidebar-divider"></div>
    <h4>Сервис</h4>
    <ul>
      <li><a href="/admin/history">История <span class="count">↩</span></a></li>
    </ul>

    <slot name="sidebar-extra" />
  </aside>

  <main class="main">
    <slot />
  </main>

</div>

<!-- Toast-уведомления -->
<div class="admin-toast" data-admin-toast hidden></div>

<!-- Sticky-панель для batch reorder: появляется когда порядок изменён,
     но ещё не сохранён. -->
<div class="reorder-bar" data-reorder-bar hidden>
  <span class="reorder-bar__msg">Порядок изменён</span>
  <button type="button" class="btn btn-ghost reorder-bar__cancel" data-reorder-cancel>Отменить</button>
  <button type="button" class="btn btn-primary reorder-bar__save" data-reorder-save>Сохранить порядок</button>
</div>

<!-- Централизованный сабмит всех форм админки. Любая форма с data-edit-form
     автоматически отправляет POST /api/admin/save и показывает результат. -->
<script>
  type ToastKind = 'info' | 'success' | 'error';
  const toast = document.querySelector<HTMLElement>('[data-admin-toast]');

  // Mobile sidebar toggle
  const sidebarBtn = document.querySelector<HTMLButtonElement>('[data-toggle-sidebar]');
  const sidebarBackdrop = document.querySelector<HTMLElement>('[data-sidebar-backdrop]');
  function closeSidebar() {
    document.body.classList.remove('cms-sidebar-open');
    sidebarBtn?.setAttribute('aria-expanded', 'false');
  }
  sidebarBtn?.addEventListener('click', () => {
    const open = document.body.classList.toggle('cms-sidebar-open');
    sidebarBtn.setAttribute('aria-expanded', String(open));
  });
  sidebarBackdrop?.addEventListener('click', closeSidebar);
  // Закрывать при клике по любой ссылке в сайдбаре — переход и так перерисует страницу,
  // но если ссылка на якорь — без этого sidebar останется открытым.
  document.querySelectorAll<HTMLElement>('.sidebar a').forEach((a) => {
    a.addEventListener('click', () => closeSidebar());
  });

  function showToast(text: string, kind: ToastKind = 'info', ms = 4000) {
    if (!toast) { alert(text); return; }
    toast.textContent = text;
    toast.dataset.kind = kind;
    toast.hidden = false;
    window.clearTimeout((toast as any)._t);
    (toast as any)._t = window.setTimeout(() => { toast.hidden = true; }, ms);
  }

  type SaveAction = 'update' | 'create' | 'delete';

  async function postSave(payload: { collection: string; action: SaveAction; key?: string; data?: Record<string, unknown> }) {
    const res = await fetch('/api/admin/save', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify(payload),
    });
    const rawText = await res.text();
    let body: any = null;
    try { body = rawText ? JSON.parse(rawText) : null; } catch { /* not json */ }
    return { res, body, rawText };
  }

  function fileToBase64(file: File): Promise<string> {
    return new Promise((resolve, reject) => {
      const reader = new FileReader();
      reader.onload = () => {
        const result = reader.result as string;
        const idx = result.indexOf(',');
        resolve(idx >= 0 ? result.slice(idx + 1) : result);
      };
      reader.onerror = () => reject(reader.error);
      reader.readAsDataURL(file);
    });
  }

  async function uploadFile(file: File, statusEl: HTMLElement | null, target?: string): Promise<string> {
    if (statusEl) {
      statusEl.hidden = false;
      statusEl.dataset.state = 'loading';
      statusEl.textContent = `Загружаю ${file.name}...`;
    }
    const contentBase64 = await fileToBase64(file);
    const res = await fetch('/api/admin/upload', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({ filename: file.name, contentBase64, target }),
    });
    const text = await res.text();
    let body: any = null;
    try { body = text ? JSON.parse(text) : null; } catch {}
    if (!res.ok || !body?.src) {
      const detail = body?.error || text.slice(0, 200) || 'пустой ответ';
      if (statusEl) { statusEl.dataset.state = 'error'; statusEl.textContent = `Ошибка: ${detail}`; }
      throw new Error(`upload failed: ${res.status} ${detail}`);
    }
    if (statusEl) { statusEl.dataset.state = 'success'; statusEl.textContent = `Загружено: ${body.src}`; }
    return body.src as string;
  }

  document.querySelectorAll<HTMLFormElement>('form[data-edit-form]').forEach((form) => {
    const collection = form.dataset.collection;
    const key = form.dataset.key;
    const formAction = (form.dataset.action as SaveAction) || 'update';
    const redirectTo = form.dataset.redirectTo;
    if (!collection) return;

    const pending = form.querySelector<HTMLElement>('[data-pending]');
    const initialState = JSON.stringify(Array.from(new FormData(form).entries()));

    form.addEventListener('input', () => {
      if (pending) {
        const current = JSON.stringify(Array.from(new FormData(form).entries()));
        pending.hidden = current === initialState;
      }
    });

    // Локальный preview выбранного файла + сброс upload status.
    const previewImg = form.querySelector<HTMLImageElement>('[data-upload-preview]');
    const previewEmpty = form.querySelector<HTMLElement>('[data-upload-empty]');
    const uploadStatus = form.querySelector<HTMLElement>('[data-upload-status]');
    form.querySelectorAll<HTMLInputElement>('input[type="file"][data-upload-target]').forEach((fi) => {
      fi.addEventListener('change', () => {
        const file = fi.files?.[0];
        if (!file || !previewImg) return;
        previewImg.src = URL.createObjectURL(file);
        previewImg.hidden = false;
        if (previewEmpty) previewEmpty.hidden = true;
        if (uploadStatus) { uploadStatus.hidden = true; uploadStatus.dataset.state = ''; }
      });
    });

    async function save(publish: boolean) {
      const btn = form.querySelector<HTMLButtonElement>(publish ? 'button[type="submit"]' : '[data-save="draft"]');
      if (btn) btn.disabled = true;

      try {
        // Перед save: аплоадим все file-input'ы с выбранным файлом,
        // подставляем полученный src в нужное текстовое поле.
        for (const fi of form.querySelectorAll<HTMLInputElement>('input[type="file"][data-upload-target]')) {
          const file = fi.files?.[0];
          if (!file) continue;
          const targetName = fi.dataset.uploadTarget!;
          const uploadFolder = fi.dataset.uploadFolder; // works | team | undefined
          try {
            const src = await uploadFile(file, uploadStatus, uploadFolder);
            const targetEl = form.querySelector<HTMLInputElement>(`[name="${targetName}"]`);
            if (targetEl) targetEl.value = src;
          } catch (err) {
            showToast(`Загрузка файла: ${String(err)}`, 'error', 8000);
            return;
          }
        }

        const data: Record<string, unknown> = Object.fromEntries(new FormData(form).entries());
        // Checkboxes не попадают в FormData когда выключены — выставляем явный boolean.
        form.querySelectorAll<HTMLInputElement>('input[type="checkbox"][name]').forEach((cb) => {
          data[cb.name] = cb.checked;
        });

        const { res, body, rawText } = await postSave({
          collection: collection!,
          action: formAction,
          key: key || undefined,
          data,
        });

        if (!res.ok) {
          const detail = body?.error || (rawText ? rawText.slice(0, 200) : 'пустой ответ');
          showToast(`HTTP ${res.status}: ${detail}`, 'error', 8000);
          console.error('save failed', res.status, rawText);
          return;
        }
        if (!body) {
          showToast(`HTTP ${res.status}, но тело пустое.`, 'error', 8000);
          return;
        }

        const verb = formAction === 'create' ? 'Создано' : 'Опубликовано';
        if (body.mode === 'dev') {
          showToast(`${verb} локально. Чтобы выкатить на прод — закоммитьте JSON.`, 'success', 5000);
        } else {
          showToast(`${verb}. Изменения появятся на сайте через ~1 минуту.`, 'success', 5000);
        }

        if (redirectTo) {
          window.setTimeout(() => { window.location.href = redirectTo; }, 800);
        }
      } catch (err) {
        showToast(`Сеть: ${String(err)}`, 'error', 6000);
        console.error(err);
      } finally {
        if (btn) btn.disabled = false;
      }
    }

    async function deleteEntry(btn: HTMLButtonElement) {
      if (!key) return;
      const label = btn.dataset.deleteLabel || 'элемент';
      if (!window.confirm(`Удалить ${label}? Действие нельзя отменить из админки.`)) return;
      btn.disabled = true;

      try {
        const { res, body, rawText } = await postSave({
          collection: collection!,
          action: 'delete',
          key,
        });
        if (!res.ok) {
          const detail = body?.error || (rawText ? rawText.slice(0, 200) : 'пустой ответ');
          showToast(`HTTP ${res.status}: ${detail}`, 'error', 8000);
          return;
        }
        showToast('Удалено. Изменения появятся на сайте через ~1 минуту.', 'success', 5000);
        const back = btn.dataset.deleteRedirect || `/admin/${collection}`;
        window.setTimeout(() => { window.location.href = back; }, 800);
      } catch (err) {
        showToast(`Сеть: ${String(err)}`, 'error', 6000);
      } finally {
        btn.disabled = false;
      }
    }

    form.addEventListener('submit', (e) => { e.preventDefault(); save(true); });
    form.querySelector('[data-save="draft"]')?.addEventListener('click', () => save(false));
    form.querySelectorAll<HTMLButtonElement>('[data-delete]').forEach((btn) => {
      btn.addEventListener('click', (e) => { e.preventDefault(); deleteEntry(btn); });
    });
  });

  // Drag-and-drop reorder для listing-страниц в batch-режиме.
  // Каждый drop только перестраивает DOM. Save идёт одним запросом по
  // нажатию «Сохранить порядок» в sticky-баре внизу.
  const reorderBar = document.querySelector<HTMLElement>('[data-reorder-bar]');
  const reorderSaveBtn = document.querySelector<HTMLButtonElement>('[data-reorder-save]');
  const reorderCancelBtn = document.querySelector<HTMLButtonElement>('[data-reorder-cancel]');

  // Активный список с pending-изменениями. На странице может быть несколько
  // reorder-listings (например 3 категории услуг), но pending-state — только
  // у одного за раз: после save/cancel сбрасывается.
  let pendingList: HTMLElement | null = null;
  let pendingSnapshot: HTMLElement[] = []; // исходный DOM-порядок дочерних элементов

  function showReorderBar() {
    if (reorderBar) reorderBar.hidden = false;
  }
  function hideReorderBar() {
    if (reorderBar) reorderBar.hidden = true;
    pendingList = null;
    pendingSnapshot = [];
  }

  function markDirty(list: HTMLElement) {
    if (pendingList && pendingList !== list) {
      // Юзер начал двигать в другом list — игнорируем (надо сначала сохранить/отменить)
      return;
    }
    if (!pendingList) {
      // Первое изменение — снимем снапшот ИСХОДНОГО DOM-порядка
      pendingList = list;
      pendingSnapshot = Array.from(list.querySelectorAll<HTMLElement>('[data-reorder-idx]'))
        .filter((el) => el.parentElement === list);
      showReorderBar();
    }
  }

  document.querySelectorAll<HTMLElement>('[data-reorder-collection]').forEach((list) => {
    const items = Array.from(list.querySelectorAll<HTMLElement>('[data-reorder-idx]'))
      .filter((el) => el.parentElement === list);
    let dragEl: HTMLElement | null = null;

    items.forEach((item) => {
      item.setAttribute('draggable', 'true');

      item.addEventListener('dragstart', (e) => {
        dragEl = item;
        item.classList.add('reorder-dragging');
        e.dataTransfer?.setData('text/plain', item.dataset.reorderIdx || '');
        if (e.dataTransfer) e.dataTransfer.effectAllowed = 'move';
      });

      item.addEventListener('dragend', () => {
        item.classList.remove('reorder-dragging');
        items.forEach((el) => el.classList.remove('reorder-over'));
        dragEl = null;
      });

      item.addEventListener('dragover', (e) => {
        e.preventDefault();
        if (e.dataTransfer) e.dataTransfer.dropEffect = 'move';
        if (item !== dragEl) item.classList.add('reorder-over');
      });

      item.addEventListener('dragleave', () => item.classList.remove('reorder-over'));

      item.addEventListener('drop', (e) => {
        e.preventDefault();
        item.classList.remove('reorder-over');
        if (!dragEl || dragEl === item) return;
        if (pendingList && pendingList !== list) {
          showToast('Сначала сохраните или отмените изменения в другом списке.', 'error', 4000);
          return;
        }

        // Перестраиваем DOM
        const dragRect = dragEl.getBoundingClientRect();
        const itemRect = item.getBoundingClientRect();
        const before = dragRect.top < itemRect.top ? item.nextSibling : item;
        list.insertBefore(dragEl, before);

        markDirty(list);
      });
    });
  });

  // «Сохранить порядок» — один POST с финальным order
  reorderSaveBtn?.addEventListener('click', async () => {
    if (!pendingList) return;
    const list = pendingList;
    const collection = list.dataset.reorderCollection!;
    const reorderKey = list.dataset.reorderKey;
    const domItems = Array.from(list.querySelectorAll<HTMLElement>('[data-reorder-idx]'))
      .filter((el) => el.parentElement === list);
    const order = domItems.map((el) => parseInt(el.dataset.reorderIdx || '0', 10));

    reorderSaveBtn.disabled = true;
    if (reorderCancelBtn) reorderCancelBtn.disabled = true;

    try {
      const res = await fetch('/api/admin/save', {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          collection,
          action: 'reorder',
          key: reorderKey || undefined,
          data: { order },
        }),
      });
      const body = await res.json().catch(() => null);
      if (!res.ok || !body?.ok) {
        showToast(`Не удалось сохранить порядок: ${body?.error || res.status}`, 'error', 6000);
        return;
      }
      showToast('Порядок сохранён. На сайте обновится через ~1 минуту.', 'success', 4000);
      // Перенумеровываем dataset.reorderIdx по новому DOM-порядку — теперь
      // он соответствует свежим JSON-позициям, и следующий батч drag-ов
      // будет корректным.
      domItems.forEach((el, i) => { el.dataset.reorderIdx = String(i); });
      hideReorderBar();
    } catch (err) {
      showToast(`Сеть: ${String(err)}`, 'error', 6000);
    } finally {
      reorderSaveBtn.disabled = false;
      if (reorderCancelBtn) reorderCancelBtn.disabled = false;
    }
  });

  // «Отменить» — восстановить исходный DOM-порядок из snapshot
  reorderCancelBtn?.addEventListener('click', () => {
    if (!pendingList || pendingSnapshot.length === 0) {
      hideReorderBar();
      return;
    }
    // Восстанавливаем по очереди: append каждый snapshot-элемент — DOM
    // сам выстроит их в исходном порядке.
    pendingSnapshot.forEach((el) => pendingList!.appendChild(el));
    hideReorderBar();
  });
</script>

<style is:global>
  @font-face { font-family: 'Disket Mono'; src: url('/assets/fonts/Disket-Mono-Regular.ttf') format('truetype'); font-weight: 400; font-display: swap; }
  @font-face { font-family: 'Disket Mono'; src: url('/assets/fonts/Disket-Mono-Bold.ttf') format('truetype'); font-weight: 700; font-display: swap; }
  /* unicode-range исключает U+00A0 (nbsp) у Gotham — иначе кириллический nbsp растягивается */
  @font-face { font-family: 'Gotham'; src: url('/assets/fonts/gotham_book.otf') format('opentype'); font-weight: 400; font-display: swap; unicode-range: U+0020-009F, U+00A1-024F, U+1E00-1EFF, U+2000-206F, U+2070-209F, U+20A0-20CF, U+2100-214F; }
  @font-face { font-family: 'Gotham'; src: url('/assets/fonts/gotham_bold.otf') format('opentype'); font-weight: 700; font-display: swap; unicode-range: U+0020-009F, U+00A1-024F, U+1E00-1EFF, U+2000-206F, U+2070-209F, U+20A0-20CF, U+2100-214F; }

  :root {
    --paper:    #EBEAE5;
    --paper-2:  #F2F1ED;
    --paper-d:  #DCDAD3;
    --ink:      #0B0B0B;
    --ink-2:    #1F1F1F;
    --forest:   #042615;
    --ash:      #A0A0A0;
    --ash-d:    #595959;
    --line:     rgba(11,11,11,.10);
    --line-d:   rgba(11,11,11,.18);
    --font-display: 'Disket Mono', monospace;
    --font-body:    'Gotham', system-ui, sans-serif;
    --font-mono:    'Disket Mono', ui-monospace, monospace;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html, body { height: 100%; }
  body.cms-body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
  }
  body.cms-body a { color: inherit; text-decoration: none; }
  body.cms-body ul { list-style: none; }
  body.cms-body input, body.cms-body select, body.cms-body textarea, body.cms-body button { font: inherit; }
  body.cms-body input, body.cms-body select, body.cms-body textarea { color: inherit; }

  /* ── LAYOUT ──────────────────────────────────────────────── */
  .cms {
    display: grid;
    grid-template-columns: 280px 1fr;
    grid-template-rows: 56px 1fr;
    min-height: 100vh;
  }

  /* ── TOP BAR ─────────────────────────────────────────────── */
  .topbar {
    grid-column: 1 / -1;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    background: var(--paper-2);
    border-bottom: 1px solid var(--line);
    position: sticky;
    top: 0;
    z-index: 10;
  }
  .brand {
    display: flex; align-items: center; gap: 12px;
  }
  .brand-mark {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 14px; letter-spacing: .12em;
  }
  .brand-mark::after {
    content: '';
    display: inline-block;
    width: 8px; height: 8px;
    background: var(--forest);
    transform: rotate(45deg);
    margin-left: 8px;
    vertical-align: middle;
  }
  .brand-sub {
    font-family: var(--font-mono);
    font-size: 10px; letter-spacing: .2em;
    color: var(--ash-d);
    text-transform: uppercase;
    border-left: 1px solid var(--line-d);
    padding-left: 12px;
  }

  .user-meta {
    display: flex; align-items: center; gap: 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ash-d);
  }
  .user-meta strong { color: var(--ink); font-weight: 700; }
  .user-meta .logout {
    border: 1px solid var(--ink);
    padding: 6px 14px;
    border-radius: 999px;
    cursor: pointer;
    transition: background .2s, color .2s;
  }
  .user-meta .logout:hover { background: var(--ink); color: var(--paper); }

  /* ── SIDEBAR ─────────────────────────────────────────────── */
  .sidebar {
    background: var(--paper-2);
    border-right: 1px solid var(--line);
    padding: 24px 0;
    overflow-y: auto;
    position: sticky;
    top: 56px;
    align-self: start;
    height: calc(100vh - 56px);
  }
  .sidebar h4 {
    font-family: var(--font-mono);
    font-size: 10px; font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ash-d);
    padding: 12px 24px 8px;
  }
  .sidebar h4::before {
    content: '';
    display: inline-block;
    width: 16px; height: 1px;
    background: var(--ash-d);
    vertical-align: middle;
    margin-right: 10px;
  }
  .sidebar li a {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 24px;
    font-size: 13px;
    border-left: 2px solid transparent;
    transition: background .15s, border-color .15s;
  }
  .sidebar li a:hover { background: var(--paper-d); }
  .sidebar li a.active {
    background: var(--paper-d);
    border-left-color: var(--forest);
    font-weight: 500;
  }
  .sidebar li a .count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ash-d);
    letter-spacing: .1em;
  }

  .sidebar-divider {
    height: 1px;
    background: var(--line);
    margin: 16px 24px;
  }

  .sidebar-items {
    font-size: 13px;
  }
  .sidebar-items li a {
    padding-left: 36px;
    position: relative;
  }
  .sidebar-items li a::before {
    content: '';
    position: absolute;
    left: 24px; top: 50%;
    width: 6px; height: 1px;
    background: var(--ash);
  }

  .sidebar-action {
    margin: 12px 24px;
  }
  .sidebar-action button,
  .sidebar-action a {
    display: block;
    width: 100%;
    background: transparent;
    border: 1px dashed var(--line-d);
    color: var(--ash-d);
    padding: 10px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 6px;
    transition: border-color .15s, color .15s;
    text-align: center;
  }
  .sidebar-action button:hover,
  .sidebar-action a:hover {
    border-color: var(--ink);
    color: var(--ink);
  }

  /* ── MAIN PANE ───────────────────────────────────────────── */
  .main {
    padding: 32px 40px;
    overflow-x: auto;
  }

  .crumbs {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ash-d);
    margin-bottom: 8px;
  }
  .crumbs a { color: var(--ash-d); transition: color .15s; }
  .crumbs a:hover { color: var(--ink); }
  .crumbs .sep { margin: 0 8px; }

  .title-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--ink);
    gap: 16px;
  }
  .page-title {
    font-family: var(--font-body); font-weight: 700;
    font-size: 28px;
    letter-spacing: -.01em;
  }
  .title-actions { display: flex; gap: 10px; align-items: center; }

  body.cms-body a.btn, body.cms-body button.btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 11px 22px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 11px;
    line-height: 1;
    letter-spacing: .14em;
    text-transform: uppercase;
    border: 1px solid var(--ink);
    border-radius: 999px;
    cursor: pointer;
    transition: background .2s, color .2s;
    text-decoration: none;
    color: var(--ink);
    background: transparent;
    min-height: 0;
    -webkit-appearance: none;
            appearance: none;
  }
  body.cms-body a.btn-primary, body.cms-body button.btn-primary { background: var(--ink); color: var(--paper); }
  body.cms-body a.btn-primary:hover, body.cms-body button.btn-primary:hover { background: var(--forest); border-color: var(--forest); }
  body.cms-body a.btn-ghost:hover, body.cms-body button.btn-ghost:hover { background: var(--ink); color: var(--paper); }
  body.cms-body button.btn-danger { border-color: #8b1d1d; color: #8b1d1d; background: transparent; }
  body.cms-body button.btn-danger:hover { background: #8b1d1d; border-color: #8b1d1d; color: var(--paper); }

  .file-input {
    display: block;
    width: 100%;
    padding: 10px 14px;
    background: var(--paper-2);
    border: 1px dashed var(--line-d);
    border-radius: 6px;
    font-size: 13px;
    color: var(--ink);
    cursor: pointer;
    transition: border-color .15s;
  }
  .file-input:hover { border-color: var(--ink); }
  .file-input::file-selector-button {
    background: var(--ink);
    color: var(--paper);
    border: none;
    padding: 6px 14px;
    margin-right: 12px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 10px;
    letter-spacing: .12em;
    text-transform: uppercase;
    cursor: pointer;
  }
  .upload-status {
    margin-top: 8px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .08em;
    color: var(--ash-d);
  }
  .upload-status[data-state="loading"] { color: var(--ink); }
  .upload-status[data-state="success"] { color: var(--forest); }
  .upload-status[data-state="error"] { color: #8b1d1d; }

  /* Drag-and-drop reorder */
  [data-reorder-idx] { cursor: grab; }
  [data-reorder-idx]:active { cursor: grabbing; }
  .reorder-dragging { opacity: .35; }
  .reorder-over { box-shadow: 0 0 0 2px var(--forest) inset; }

  /* Sticky-панель batch-сохранения порядка */
  .reorder-bar {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 1000;
    background: var(--ink);
    color: var(--paper);
    padding: 12px 14px 12px 22px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    gap: 14px;
    box-shadow: 0 10px 40px rgba(0,0,0,0.3), 0 2px 8px rgba(0,0,0,0.15);
    animation: reorder-bar-in .25s cubic-bezier(.2,.7,.3,1);
  }
  .reorder-bar[hidden] { display: none; }
  .reorder-bar__msg {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
  }
  body.cms-body .reorder-bar .btn { padding: 9px 18px; font-size: 10px; }
  body.cms-body .reorder-bar .btn-ghost { color: var(--paper); border-color: rgba(235,234,229,.4); background: transparent; }
  body.cms-body .reorder-bar .btn-ghost:hover { background: rgba(235,234,229,.12); color: var(--paper); }
  body.cms-body .reorder-bar .btn-primary { background: var(--paper); color: var(--ink); border-color: var(--paper); }
  body.cms-body .reorder-bar .btn-primary:hover { background: var(--paper-2); border-color: var(--paper-2); color: var(--ink); }
  @keyframes reorder-bar-in {
    from { transform: translate(-50%, 30px); opacity: 0; }
    to { transform: translate(-50%, 0); opacity: 1; }
  }
  @media (max-width: 600px) {
    .reorder-bar { left: 12px; right: 12px; transform: none; border-radius: 14px; flex-wrap: wrap; }
    @keyframes reorder-bar-in {
      from { transform: translateY(30px); opacity: 0; }
      to { transform: translateY(0); opacity: 1; }
    }
  }

  /* ── Mobile: hamburger + collapsible sidebar ──────────────── */
  .mobile-menu-btn {
    display: none;
    background: none;
    border: none;
    padding: 8px;
    margin-right: 4px;
    cursor: pointer;
    flex-direction: column;
    gap: 4px;
    align-items: stretch;
    width: 36px;
  }
  .mobile-menu-btn span {
    height: 2px;
    background: var(--ink);
    border-radius: 1px;
    transition: transform .2s, opacity .2s;
  }
  .sidebar-backdrop {
    display: none;
    position: fixed;
    inset: 56px 0 0 0;
    background: rgba(11,11,11,.45);
    z-index: 8;
    backdrop-filter: blur(2px);
  }
  .sidebar-backdrop[hidden] { display: none; }

  @media (max-width: 760px) {
    .cms { grid-template-columns: 1fr; }
    .topbar { padding: 0 16px; }
    .mobile-menu-btn { display: inline-flex; }
    .user-meta__role { display: none; }
    .user-meta { gap: 10px; }
    .brand-sub { display: none; }
    .main { padding: 24px 16px; }

    .sidebar {
      position: fixed;
      top: 56px;
      left: 0;
      width: 280px;
      max-width: 85vw;
      height: calc(100vh - 56px);
      z-index: 9;
      transform: translateX(-100%);
      transition: transform .25s cubic-bezier(.2,.7,.3,1);
      box-shadow: 4px 0 24px rgba(0,0,0,.12);
    }
    body.cms-sidebar-open .sidebar { transform: translateX(0); }
    body.cms-sidebar-open .sidebar-backdrop { display: block; }
    body.cms-sidebar-open .mobile-menu-btn span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    body.cms-sidebar-open .mobile-menu-btn span:nth-child(2) { opacity: 0; }
    body.cms-sidebar-open .mobile-menu-btn span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
  }
  .btn .dot {
    width: 8px; height: 8px;
    background: currentColor;
    border-radius: 50%;
  }

  .status-pill {
    display: inline-flex; align-items: center; gap: 6px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    text-transform: uppercase;
    padding: 3px 10px;
    border-radius: 999px;
    background: var(--paper-d);
    color: var(--ink);
  }
  .status-pill::before {
    content: '';
    width: 6px; height: 6px;
    border-radius: 50%;
    background: var(--forest);
  }
  .status-pill--draft::before { background: var(--ash); }

  /* ── FORM ───────────────────────────────────────────────── */
  .form-grid {
    display: grid;
    grid-template-columns: 1fr 360px;
    gap: 40px;
    align-items: flex-start;
  }
  @media (max-width: 1100px) {
    .form-grid { grid-template-columns: 1fr; }
  }

  .field {
    margin-bottom: 22px;
  }
  .field-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 10px; font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ash-d);
    margin-bottom: 6px;
  }
  .field-label .required { color: var(--forest); margin-left: 4px; }
  .field-hint {
    display: block;
    font-size: 12px;
    color: var(--ash-d);
    margin-top: 4px;
  }
  .input, .select, .textarea {
    display: block;
    width: 100%;
    padding: 12px 14px;
    background: var(--paper-2);
    border: 1px solid var(--line-d);
    border-radius: 6px;
    font-size: 14px;
    color: var(--ink);
    outline: none;
    transition: border-color .15s, background .15s;
  }
  .input:focus, .select:focus, .textarea:focus {
    border-color: var(--ink);
    background: #fff;
  }
  .input.price {
    font-family: var(--font-mono);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    letter-spacing: .04em;
  }
  .input-with-suffix {
    position: relative;
  }
  .input-with-suffix .input { padding-right: 40px; }
  .input-with-suffix .suffix {
    position: absolute;
    right: 14px; top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-mono);
    color: var(--ash-d);
    font-size: 14px;
  }
  .textarea { min-height: 100px; resize: vertical; line-height: 1.55; }

  .fieldset-2 {
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: 16px;
  }

  .checkbox {
    display: flex; align-items: center; gap: 10px;
    font-size: 13px;
    cursor: pointer;
    user-select: none;
  }
  .checkbox input { display: none; }
  .checkbox .box {
    width: 18px; height: 18px;
    border: 1px solid var(--ink);
    border-radius: 4px;
    position: relative;
    background: var(--paper-2);
    flex-shrink: 0;
  }
  .checkbox input:checked + .box { background: var(--forest); border-color: var(--forest); }
  .checkbox input:checked + .box::after {
    content: '';
    position: absolute;
    left: 4px; top: 1px;
    width: 6px; height: 11px;
    border-right: 2px solid var(--paper);
    border-bottom: 2px solid var(--paper);
    transform: rotate(45deg);
  }

  /* ── PREVIEW PANE ───────────────────────────────────────── */
  .preview {
    position: sticky; top: 88px;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 24px;
  }
  .preview-tag {
    font-family: var(--font-mono);
    font-size: 10px; font-weight: 700;
    letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ash-d);
    margin-bottom: 16px;
  }
  .preview-tag::before {
    content: '';
    display: inline-block;
    width: 20px; height: 1px;
    background: var(--ash-d);
    vertical-align: middle;
    margin-right: 10px;
  }
  .preview-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 18px;
    margin-bottom: 16px;
  }
  .preview-row {
    display: flex; justify-content: space-between; align-items: baseline;
    padding: 10px 0;
    border-top: 1px solid var(--line);
    gap: 12px;
  }
  .preview-row:first-child { border-top: none; padding-top: 0; }
  .preview-row .name { color: var(--ink); font-size: 14px; }
  .preview-row .price {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 14px; color: var(--ink);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }
  .preview-row.highlight {
    background: rgba(4,38,21,.06);
    margin: 0 -10px;
    padding-left: 10px; padding-right: 10px;
    border-radius: 6px;
  }
  .preview-row.highlight .name,
  .preview-row.highlight .price { color: var(--forest); font-weight: 700; }
  .preview-note {
    font-size: 11px;
    color: var(--ash-d);
    line-height: 1.5;
    margin-top: 8px;
  }

  .form-foot {
    margin-top: 32px;
    padding-top: 24px;
    border-top: 1px solid var(--line);
    display: flex; gap: 12px; justify-content: flex-end;
    flex-wrap: wrap;
  }
  .form-foot .pending {
    margin-right: auto;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--ash-d);
    display: inline-flex; align-items: center; gap: 8px;
  }
  .form-foot .pending::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--ash);
    border-radius: 50%;
  }

  /* ── COLLECTION LIST ─────────────────────────────────────── */
  .col-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 14px;
  }
  .col-item {
    display: block;
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 18px 20px;
    transition: border-color .15s, transform .15s;
  }
  .col-item:hover {
    border-color: var(--ink);
    transform: translateY(-1px);
  }
  .col-item-head {
    display: flex; justify-content: space-between; align-items: baseline;
    margin-bottom: 8px;
  }
  .col-item-cat {
    font-family: var(--font-mono); font-size: 10px;
    letter-spacing: .2em; text-transform: uppercase;
    color: var(--ash-d);
  }
  .col-item-price {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 14px; font-variant-numeric: tabular-nums;
    color: var(--ink);
  }
  .col-item-name {
    font-size: 16px;
    color: var(--ink);
    font-weight: 500;
    margin-bottom: 4px;
  }
  .col-item-meta {
    font-size: 12px; color: var(--ash-d);
  }
  .col-group {
    margin-bottom: 28px;
  }
  .col-group-title {
    font-family: var(--font-mono); font-weight: 700;
    font-size: 11px; letter-spacing: .2em;
    text-transform: uppercase;
    color: var(--ink);
    margin-bottom: 14px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .col-group-title .count {
    color: var(--ash-d); font-weight: 400;
  }

  /* ── TOAST ────────────────────────────────────────────────── */
  .admin-toast {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 999;
    background: var(--ink);
    color: var(--paper);
    padding: 14px 20px;
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: .06em;
    max-width: 420px;
    line-height: 1.45;
    box-shadow: 0 10px 40px rgba(11,11,11,.25);
    animation: admin-toast-in .25s var(--ease-out, ease-out);
  }
  .admin-toast[data-kind="success"] { background: var(--forest); }
  .admin-toast[data-kind="error"] { background: #8b1d1d; color: #fff; }
  @keyframes admin-toast-in {
    from { transform: translateY(16px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }
</style>
</body>
</html>
